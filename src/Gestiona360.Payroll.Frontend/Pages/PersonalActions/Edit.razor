    private void MarkUploadedDocuments()
    {
        if (!_allExistingDocuments.Any()) return;

        foreach (var req in _requiredDocuments)
        {
            var exactMatch = _allExistingDocuments.FirstOrDefault(d =>
                !string.IsNullOrEmpty(d.DocumentType) &&
                d.DocumentType.Equals(req.DocumentName, StringComparison.OrdinalIgnoreCase));

            DocumentAttachmentDto? fuzzyMatch = null;
            if (exactMatch == null)
            {
                var reqWords = req.DocumentName
                    .ToLower()
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Where(w => w.Length > 3)
                    .ToList();

                fuzzyMatch = _allExistingDocuments.FirstOrDefault(d =>
                {
                    if (string.IsNullOrEmpty(d.FileName)) return false;
                    var fileNameLower = d.FileName.ToLower();
                    return reqWords.Any(w => fileNameLower.Contains(w));
                });
            }

            var match = exactMatch ?? fuzzyMatch;
            if (match != null)
            {
                req.IsUploaded = true;
                req.FileName = match.FileName;
                req.FileUrl = match.FileUrl;
            }
        }
    }

    private void SeparateExtraDocuments()
    {
        _extraDocuments = new();

        var assignedUrls = _requiredDocuments
            .Where(r => r.IsUploaded)
            .Select(r => r.FileUrl)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _extraDocuments = _allExistingDocuments
            .Where(d => !string.IsNullOrEmpty(d.FileUrl) && !assignedUrls.Contains(d.FileUrl))
            .ToList();
    }

