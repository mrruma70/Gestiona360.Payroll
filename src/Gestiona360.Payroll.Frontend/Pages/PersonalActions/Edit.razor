    private async Task OnFileSelectedInternal(InputFileChangeEventArgs e, UIDocumentRequirement doc)
    {
        var file = e.File;
        if (file == null) return;
        if (_isUploading) return;
        _isUploading = true;
        StateHasChanged();
        try
        {
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            if (!new[] { ".pdf", ".jpg", ".jpeg", ".png" }.Contains(ext))
            {
                Snackbar.Add("Formato no permitido. Use PDF, JPG o PNG.", Severity.Warning);
                return;
            }
            if (file.Size > 5 * 1024 * 1024)
            {
                Snackbar.Add("El archivo no puede superar los 5 MB.", Severity.Warning);
                return;
            }
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            content.Add(streamContent, "file", file.Name);
            var response = await Http.PostAsync("api/documents/upload?folder=personal-actions", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<DocumentUploadResult>();

                doc.IsUploaded = true;
                doc.FileName = file.Name;
                doc.FileUrl = result!.url;

                var newDoc = new DocumentAttachmentDto
                {
                    FileName = file.Name,
                    FileUrl = result.url,
                    ContentType = file.ContentType,
                    FileSizeBytes = file.Size,
                    UploadedAt = DateTime.UtcNow,
                    IsRequired = doc.IsMandatory,
                    DocumentType = doc.DocumentName
                };

                _dto.Documents.Add(newDoc);
                _allExistingDocuments.Add(newDoc);

                Snackbar.Add($"Documento '{file.Name}' subido correctamente.", Severity.Success);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error al subir: {error}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _isUploading = false; StateHasChanged(); }
    }

    private void RemoveDocument(UIDocumentRequirement doc)
    {
        var urlToRemove = doc.FileUrl;
        doc.IsUploaded = false;
        doc.FileName = "";
        doc.FileUrl = "";

        var item = _dto.Documents.FirstOrDefault(d => d.FileUrl == urlToRemove);
        if (item != null) _dto.Documents.Remove(item);

        var existingItem = _allExistingDocuments.FirstOrDefault(d => d.FileUrl == urlToRemove);
        if (existingItem != null) _allExistingDocuments.Remove(existingItem);

        StateHasChanged();
    }

    private void RemoveExtraDocument(DocumentAttachmentDto doc)
    {
        var urlToRemove = doc.FileUrl;

        var item = _dto.Documents.FirstOrDefault(d => d.FileUrl == urlToRemove);
        if (item != null) _dto.Documents.Remove(item);

        var existingItem = _allExistingDocuments.FirstOrDefault(d => d.FileUrl == urlToRemove);
        if (existingItem != null) _allExistingDocuments.Remove(existingItem);

        _extraDocuments.Remove(doc);

        StateHasChanged();
    }

    private async Task SaveActionAsync(bool executeImmediately)
    {
        if (_form != null) await _form.Validate();
        if (!_isFormValid || (executeImmediately && !CanExecuteNow)) return;

        _dto.EffectiveDate = _effectiveDate ?? DateTime.Today;
        _dto.ExecuteImmediately = executeImmediately;

        if (_currentEmployee != null)
    {
        _dto.EmployeeId = _currentEmployee.Id;
    }


        if (_dto.ActionType == "BankAccountChange")
        {
            _dto.NewBankId = _selectedBankId > 0 ? _selectedBankId : null;
            var selectedBank = _banksList.FirstOrDefault(b => b.Id == _selectedBankId);
            _dto.NewBankName = selectedBank?.Name;
        }

        try
        {
            var response = await Http.PutAsJsonAsync($"api/personalactions/{Id}", _dto);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(executeImmediately ? "Acción actualizada y ejecutada exitosamente." : "Acción actualizada como borrador.", Severity.Success);
                Navigation.NavigateTo("/personal-actions");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                string errorMsg = errorContent;
                try
                {
                    var jsonDoc = System.Text.Json.JsonDocument.Parse(errorContent);
                    if (jsonDoc.RootElement.TryGetProperty("title", out var title)) errorMsg = title.GetString();
                    else if (jsonDoc.RootElement.TryGetProperty("detail", out var detail)) errorMsg = detail.GetString();
                    else if (jsonDoc.RootElement.TryGetProperty("message", out var message)) errorMsg = message.GetString();
                }
                catch { }
                Snackbar.Add($"Error: {errorMsg}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error de conexión: {ex.Message}", Severity.Error); }
    }

    private void Cancel() => Navigation.NavigateTo("/personal-actions");

