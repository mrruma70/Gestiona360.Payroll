                SuspensionType = actionDetail.SuspensionType,
                SuspensionStartDate = actionDetail.SuspensionStartDate,
                SuspensionEndDate = actionDetail.SuspensionEndDate,
                TerminationType = actionDetail.TerminationType,
                IsJustified = actionDetail.IsJustified,
                Documents = new()
            };

            _effectiveDate = actionDetail.EffectiveDate;
