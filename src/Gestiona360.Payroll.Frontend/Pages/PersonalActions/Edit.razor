    private void LoadExistingDocuments(PersonalActionDetailDto actionDetail)
    {
        _allExistingDocuments = new();

        if (actionDetail.Documents != null && actionDetail.Documents.Any())
        {
            _allExistingDocuments = actionDetail.Documents.Select(d => new DocumentAttachmentDto
            {
                FileName = d.FileName,
                FileUrl = d.FileUrl,
                ContentType = d.ContentType,
                FileSizeBytes = d.FileSizeBytes,
                UploadedAt = d.UploadedAt,
                IsRequired = d.IsRequired,
                DocumentType = d.DocumentType
            }).ToList();
        }
        else if (!string.IsNullOrEmpty(actionDetail.DocumentAttachmentsJson))
        {
            try
            {
                _allExistingDocuments = System.Text.Json.JsonSerializer.Deserialize<List<DocumentAttachmentDto>>(
                    actionDetail.DocumentAttachmentsJson) ?? new();
            }
            catch
            {
                _allExistingDocuments = new();
            }
        }

        _dto.Documents = _allExistingDocuments.Select(d => new DocumentAttachmentDto
        {
            FileName = d.FileName,
            FileUrl = d.FileUrl,
            ContentType = d.ContentType,
            FileSizeBytes = d.FileSizeBytes,
            UploadedAt = d.UploadedAt,
            IsRequired = d.IsRequired,
            DocumentType = d.DocumentType
        }).ToList();
    }

