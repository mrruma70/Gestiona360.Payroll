                !string.Equals(actionDetail.Status, "Pending", StringComparison.OrdinalIgnoreCase))
            {
                _isEditable = false;
                _isLoading = false;
                StateHasChanged();
                return;
            }

            _isEditable = true;

            _dto = new ExtendedActionDto
            {
                Id = actionDetail.Id,
                EmployeeId = actionDetail.EmployeeId,
                EffectiveDate = actionDetail.EffectiveDate,
                ActionType = actionDetail.ActionType,
                CausalDescription = actionDetail.CausalDescription,
                Justification = actionDetail.Justification,
                OldBaseSalary = actionDetail.OldBaseSalary,
                NewBaseSalary = actionDetail.NewBaseSalary,
                NewJobGradeId = actionDetail.NewJobGradeId,
                NewJobGradeName = actionDetail.NewJobGradeName,
                NewContractTypeId = actionDetail.NewContractTypeId,
                NewContractTypeName = actionDetail.NewContractTypeName,
                NewShiftId = actionDetail.NewShiftId,
                NewShiftName = actionDetail.NewShiftName,
                NewCostCenterId = actionDetail.NewCostCenterId,
                NewCostCenterName = actionDetail.NewCostCenterName,
                NewHealthProviderId = actionDetail.NewHealthProviderId,
                NewHealthProviderName = actionDetail.NewHealthProviderName,
                NewBankId = actionDetail.NewBankId,
                NewBankAccountNumber = actionDetail.NewBankAccountNumber,
