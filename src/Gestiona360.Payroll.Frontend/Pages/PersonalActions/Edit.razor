    private void PreloadAutocompleteSelections()
    {
        if (_dto.NewJobGradeId.HasValue)
            _newJobGradeSelected = new JobGradeDto { Id = _dto.NewJobGradeId.Value, Name = _dto.NewJobGradeName ?? "" };
        if (_dto.NewContractTypeId.HasValue)
            _newContractTypeSelected = new ContractTypeDto { Id = _dto.NewContractTypeId.Value, Name = _dto.NewContractTypeName ?? "" };
        if (_dto.NewShiftId.HasValue)
