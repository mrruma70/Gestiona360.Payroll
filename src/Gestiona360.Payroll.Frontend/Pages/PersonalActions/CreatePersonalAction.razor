@page "/personal-actions/create"
@using Gestiona360.Payroll.Application.Contracts.DTOs.PersonalActions
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation


<PageTitle>Nueva Acción Individual | Gestiona360</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudPaper Class="pa-6" Elevation="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
            <MudText Typo="Typo.h5"><b>➕ Nueva Acción de Personal (Individual)</b></MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" OnClick="Cancel">X Cancelar</MudButton>
        </MudStack>

        <MudText Typo="Typo.subtitle2" Class="mb-2">📌 CONTEXTO DE APLICACIÓN</MudText>
        <MudAlert Severity="@(_periodInfo?.IsOpen == true ? Severity.Success : Severity.Warning)" Class="mb-6" Icon="@Icons.Material.Filled.CheckCircle">
            📅 Período de Nómina Destino: <b>@(_periodInfo?.Name ?? "Cargando...")</b> &nbsp;|&nbsp;
            ℹ️ Estado: <b>@(_periodInfo?.Status ?? "...")</b>
        </MudAlert>

        <MudForm @ref="_form" Model="@_dto" IsValidChanged="(valid) => _isFormValid = valid">

            @* 1️⃣ SELECCIÓN DEL EMPLEADO *@
            <MudDivider Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">1️⃣ SELECCIÓN DEL EMPLEADO</MudText>

            <MudAutocomplete T="EmployeeSearchDto" Label="🔍 Buscar empleado"
                             SearchFunc="SearchEmployeesAsync"
                             ValueChanged="OnEmployeeSelectedAsync"
                             Value="_currentEmployee"
                             ToStringFunc="EmployeeToString"
                             Variant="Variant.Outlined" Class="mb-4"
                             ResetValueOnEmptyText="true" Clearable="true"
                             Required="true" RequiredError="Debe seleccionar un empleado." />

            @if (_currentEmployee != null)
            {
                <MudPaper Class="pa-4 mb-6" Outlined="true" Style="background-color: #f8fafc;">
                    <MudText Typo="Typo.subtitle2" Class="mb-3" Color="Color.Dark">📊 RESUMEN ACTUAL (Solo lectura):</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="3"><MudTextField T="decimal" Label="💰 Salario Base" Value="@_currentEmployee.BaseSalary" ReadOnly="true" Variant="Variant.Text" Adornment="Adornment.Start" AdornmentText="C$" /></MudItem>
                        <MudItem xs="12" md="3"><MudTextField T="string" Label="💼 Puesto" Value="@_currentEmployee.JobGradeName" ReadOnly="true" Variant="Variant.Text" /></MudItem>
                        <MudItem xs="12" md="3"><MudTextField T="string" Label="⏰ Turno" Value="@_currentEmployee.ShiftName" ReadOnly="true" Variant="Variant.Text" /></MudItem>
                        <MudItem xs="12" md="3"><MudTextField T="string" Label="🏢 Centro Costo" Value="@_currentEmployee.CostCenterName" ReadOnly="true" Variant="Variant.Text" /></MudItem>
                    </MudGrid>
                </MudPaper>
            }

            @* 2️⃣ CONFIGURACIÓN DEL CAMBIO *@
            <MudDivider Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">2️⃣ CONFIGURACIÓN DEL CAMBIO</MudText>

            <MudGrid Class="mb-6">
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Tipo de Acción" Value="@_dto.ActionType" ValueChanged="OnActionTypeChanged" Variant="Variant.Outlined" Required="true">
                        <MudSelectItem Value="@("SalaryChange")">💰 Cambio de Salario</MudSelectItem>
                        <MudSelectItem Value="@("PositionChange")">💼 Cambio de Puesto</MudSelectItem>
                        <MudSelectItem Value="@("ContractChange")">📄 Cambio de Contrato</MudSelectItem>
                        <MudSelectItem Value="@("ShiftChange")">⏰ Cambio de Turno</MudSelectItem>
                        <MudSelectItem Value="@("CostCenterChange")">🏢 Cambio de Centro Costo</MudSelectItem>
                        <MudSelectItem Value="@("HealthProviderChange")">🏥 Cambio de Proveedor de Salud</MudSelectItem>
                        <MudSelectItem Value="@("BankAccountChange")">🏦 Cambio de Cuenta Bancaria</MudSelectItem>
                        <MudSelectItem Value="@("Suspension")">⏸️ Suspensión</MudSelectItem>
                        <MudSelectItem Value="@("Reinstatement")">🔄 Reincorporación</MudSelectItem>
                        <MudSelectItem Value="@("Termination")">🛑 Terminación</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker Label="Fecha de Efecto" @bind-Date="_effectiveDate" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    @if (_hasCausalList)
                    {
                        <MudSelect T="string" @bind-Value="_dto.CausalDescription" Label="Causal Legal" Variant="Variant.Outlined" Required="true">
                            @foreach (var c in _availableCausals)
                            {
                                <MudSelectItem Value="@c">@c</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudTextField T="string" @bind-Value="_dto.CausalDescription" Label="Causal Legal" Variant="Variant.Outlined" Required="true" />
                    }
                </MudItem>
            </MudGrid>

            @* Campos dinámicos por tipo de acción *@
            @if (_dto.ActionType == "SalaryChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?" Value="@_dto.OldBaseSalary" Label="Salario Actual" Variant="Variant.Filled" ReadOnly="true" Adornment="Adornment.Start" AdornmentText="C$" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?" Value="@_dto.NewBaseSalary" ValueChanged="ValidateSalaryRealTime" Label="Nuevo Salario" Variant="Variant.Outlined" Immediate="true" Adornment="Adornment.Start" AdornmentText="C$" Error="@_hasSalaryError" ErrorText="@_salaryErrorMessage" />
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "PositionChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.JobGradeName" Label="Puesto Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="JobGradeDto" Label="Nuevo Puesto" SearchFunc="SearchJobGrades"
                                         ValueChanged="@((JobGradeDto v) => { _dto.NewJobGradeId = v?.Id; _dto.NewJobGradeName = v?.Name; ValidateIntegrity("Pos", v?.Id, _currentEmployee?.JobGradeId); })"
                                         ToStringFunc="JobGradeToString" Clearable="true" />
                        @if (_integrityErrors.Contains("Pos"))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">❌ Debe ser diferente al puesto actual.</MudText>
                        }
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?" Value="@_dto.NewBaseSalary" ValueChanged="ValidateSalaryRealTime" Label="Nuevo Salario (opcional)" Variant="Variant.Outlined" Immediate="true" Adornment="Adornment.Start" AdornmentText="C$" Error="@_hasSalaryError" ErrorText="@_salaryErrorMessage" />
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "ContractChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.ContractTypeName" Label="Contrato Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="ContractTypeDto" Label="Nuevo Tipo de Contrato" SearchFunc="SearchContractTypes"
                                         ValueChanged="@((ContractTypeDto v) =>
                                         {
                                             _dto.NewContractTypeId = v?.Id;
                                             if (v?.Id == _currentEmployee?.ContractTypeId)
                                                 _integrityErrors.Add("Contract");
                                             else
                                                 _integrityErrors.Remove("Contract");
                                         })"
                                         ToStringFunc="ContractTypeToString" Clearable="true" />
                        @if (_integrityErrors.Contains("Contract"))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">❌ Debe ser diferente al contrato actual.</MudText>
                        }
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "ShiftChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.ShiftName" Label="Turno Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="ShiftDto" Label="Nuevo Turno" SearchFunc="SearchShifts"
                                         ValueChanged="@((ShiftDto v) => { _dto.NewShiftId = v?.Id; ValidateIntegrity("Shift", v?.Id, _currentEmployee?.ShiftId); })"
                                         ToStringFunc="ShiftToString" Clearable="true" />
                        @if (_integrityErrors.Contains("Shift"))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">❌ Debe ser diferente al turno actual.</MudText>
                        }
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "CostCenterChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.CostCenterName" Label="Centro Costo Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="CostCenterDto" Label="Nuevo Centro de Costo" SearchFunc="SearchCostCenters"
                                         ValueChanged="@((CostCenterDto v) => { _dto.NewCostCenterId = v?.Id; ValidateIntegrity("CC", v?.Id, _currentEmployee?.CostCenterId); })"
                                         ToStringFunc="CostCenterToString" Clearable="true" />
                        @if (_integrityErrors.Contains("CC"))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">❌ Debe ser diferente al centro actual.</MudText>
                        }
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "HealthProviderChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.HealthProviderName" Label="Proveedor Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="HealthProviderDto" Label="Nuevo Proveedor de Salud" SearchFunc="SearchHealthProviders"
                                         ValueChanged="@((HealthProviderDto v) => { _dto.NewHealthProviderId = v?.Id; _dto.NewHealthProviderName = v?.Name; ValidateIntegrity("Health", v?.Id, _currentEmployee?.HealthProviderId); })"
                                         ToStringFunc="HealthProviderToString" Clearable="true" />
                        @if (_integrityErrors.Contains("Health"))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">❌ Debe ser diferente al proveedor actual.</MudText>
                        }
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "BankAccountChange")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.BankName" Label="Banco Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Value="@_currentEmployee?.BankAccountNumber" Label="Cuenta Actual" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="int" @bind-Value="_selectedBankId" Label="Nuevo Banco" Variant="Variant.Outlined" Required="true">
                            <MudSelectItem Value="0">-- Seleccione un banco --</MudSelectItem>
                            @foreach (var bank in _banksList)
                            {
                                <MudSelectItem Value="bank.Id">@bank.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" @bind-Value="_dto.NewBankAccountNumber" Label="Nueva Cuenta Bancaria" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "Suspension")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" @bind-Value="_dto.SuspensionType" Label="Tipo de Suspensión" Variant="Variant.Outlined" Required="true">
                            <MudSelectItem Value="@("MedicalLeave")">🩺 Médica</MudSelectItem>
                            <MudSelectItem Value="@("OccupationalRisk")">⚠️ Riesgo profesional</MudSelectItem>
                            <MudSelectItem Value="@("LegalDisciplinary")">⚖️ Disciplinaria</MudSelectItem>
                            <MudSelectItem Value="@("MutualConsent")">🤝 Mutuo acuerdo</MudSelectItem>
                            <MudSelectItem Value="@("CivicDuty")">🗳️ Deber cívico</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="_dto.SuspensionStartDate" Label="Fecha Inicio" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="_dto.SuspensionEndDate" Label="Fecha Fin (opcional)" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            }
            else if (_dto.ActionType == "Reinstatement")
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    Se reincorporará al empleado desde su suspensión activa.
                </MudAlert>
            }
            else if (_dto.ActionType == "Termination")
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" @bind-Value="_dto.TerminationType" Label="Tipo de Terminación" Variant="Variant.Outlined" Required="true">
                            <MudSelectItem Value="@("Resignation")">📄 Renuncia voluntaria</MudSelectItem>
                            <MudSelectItem Value="@("UnfairDismissal")">⚖️ Despido injustificado</MudSelectItem>
                            <MudSelectItem Value="@("JustifiedDismissal")">🔍 Despido justificado</MudSelectItem>
                            <MudSelectItem Value="@("MutualAgreement")">🤝 Mutuo acuerdo</MudSelectItem>
                            <MudSelectItem Value="@("Bankruptcy")">🏚️ Quiebra / Cierre</MudSelectItem>
                            <MudSelectItem Value="@("Death")">⚰️ Fallecimiento</MudSelectItem>
                            <MudSelectItem Value="@("Probation")">📆 Período de prueba</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSwitch T="bool?" @bind-Checked="_dto.IsJustified" Label="¿Justificado?" Class="mt-4" />
                    </MudItem>
                </MudGrid>
            }

            @* 3️⃣ JUSTIFICACIÓN *@
            <MudDivider Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">3️⃣ JUSTIFICACIÓN</MudText>

            <MudTextField T="string" @bind-Value="_dto.Justification" Immediate="true"
                          Label="📝 Justificación Obligatoria" Variant="Variant.Outlined" Lines="3"
                          HelperText="@($"{_dto.Justification?.Length ?? 0} caracteres ingresados (Mín. 20)")"
                          Required="true" RequiredError="La justificación es obligatoria." Class="mb-6" />

            @* 4️⃣ SOPORTE DOCUMENTAL *@
            <MudDivider Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">4️⃣ SOPORTE DOCUMENTAL</MudText>

            <MudPaper Class="pa-4 mb-6" Outlined="true">
                <MudText Typo="Typo.body2" Class="mb-4">Documentos requeridos para <b>@(_dto.ActionType ?? "esta acción")</b>:</MudText>
                @foreach (var doc in _requiredDocuments)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudIcon Icon="@(doc.IsUploaded ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                                 Color="@(doc.IsMandatory && !doc.IsUploaded ? Color.Error : Color.Success)" />
                        <MudText Typo="Typo.body2">@(doc.IsMandatory ? "☑️ *" : "☐") @doc.DocumentName</MudText>
                        <MudSpacer />
                        @if (doc.IsUploaded)
                        {
                            <MudText Typo="Typo.caption" Class="mr-2">📄 @doc.FileName</MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => RemoveDocument(doc)">🗑️</MudButton>
                            <MudText Typo="Typo.body2" Color="Color.Success" Class="ml-2"><b>✅ Cargado</b></MudText>
                        }
                        else
                        {
                            var inputId = $"fileInput_{doc.GetHashCode()}";
                            <InputFile id="@inputId" style="display: none;"
                                       OnChange="@(e => OnFileSelectedInternal(e, doc))"
                                       accept=".pdf,.jpg,.jpeg,.png" />
                            <label for="@inputId" class="mud-button-root mud-button-outlined mud-button-outlined-primary mud-button-outlined-size-small mud-ripple"
                                   style="cursor: pointer; display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px;">
                                + Adjuntar archivo
                            </label>
                        }
                    </MudStack>
                }
            </MudPaper>

            @* RESUMEN Y ACCIONES *@
            <MudDivider Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Warning">⚠️ RESUMEN DE IMPACTO Y ACCIONES</MudText>

            <MudAlert Severity="Severity.Warning" Class="mb-6" Outlined="true">
                <MudText Typo="Typo.body2" Class="mb-2">Al guardar esta acción, se registrará el cambio para el empleado:</MudText>
                @if (_currentEmployee != null)
                {
                    <MudText Typo="Typo.body2" Class="mb-2">
                        👤 <b>@_currentEmployee.FullName (@_currentEmployee.Identification)</b> |
                        @if (_dto.ActionType == "SalaryChange")
                        {
                            <span>💰 Salario: C$@(_dto.OldBaseSalary?.ToString("N2") ?? "0.00") ➔ C$@(_dto.NewBaseSalary?.ToString("N2") ?? "0.00")</span>
                        }
                        else if (_dto.ActionType == "PositionChange")
                        {
                            <span>💼 Puesto: @_currentEmployee.JobGradeName ➔ @(_dto.NewJobGradeName ?? "Nuevo")</span>
                            if (_dto.NewBaseSalary.HasValue)
                            {
                                <span> | 💰 Salario: C$@(_dto.OldBaseSalary?.ToString("N2")) ➔ C$@(_dto.NewBaseSalary.Value.ToString("N2"))</span>
                            }
                        }
                        else if (_dto.ActionType == "ContractChange")
                        {
                            <span>📄 Contrato: @_currentEmployee.ContractTypeName ➔ @(_dto.NewContractTypeName ?? "Nuevo")</span>
                        }
                        else if (_dto.ActionType == "ShiftChange")
                        {
                            <span>⏰ Turno: @_currentEmployee.ShiftName ➔ @(_dto.NewShiftName ?? "Nuevo")</span>
                        }
                        else if (_dto.ActionType == "CostCenterChange")
                        {
                            <span>🏢 Centro Costo: @_currentEmployee.CostCenterName ➔ @(_dto.NewCostCenterName ?? "Nuevo")</span>
                        }
                        else if (_dto.ActionType == "HealthProviderChange")
                        {
                            <span>🏥 Proveedor Salud: @_currentEmployee.HealthProviderName ➔ @(_dto.NewHealthProviderName ?? "Nuevo")</span>
                        }
                        else if (_dto.ActionType == "BankAccountChange")
                        {
                            <span>🏦 Cuenta: @_currentEmployee.BankAccountNumber ➔ @(_dto.NewBankAccountNumber ?? "Nueva")</span>
                        }
                        else if (_dto.ActionType == "Suspension")
                        {
                            <span>⏸️ Suspensión @(_dto.SuspensionType == "MedicalLeave" ? "Médica" : _dto.SuspensionType == "OccupationalRisk" ? "Riesgo profesional" : _dto.SuspensionType == "LegalDisciplinary" ? "Disciplinaria" : _dto.SuspensionType == "MutualConsent" ? "Mutuo acuerdo" : "Deber cívico") desde @(_dto.SuspensionStartDate?.ToString("dd/MM/yyyy")) hasta @(_dto.SuspensionEndDate?.ToString("dd/MM/yyyy") ?? "indefinido")</span>
                        }
                        else if (_dto.ActionType == "Reinstatement")
                        {
                            <span>🔄 Reincorporación desde suspensión activa</span>
                        }
                        else if (_dto.ActionType == "Termination")
                        {
                            <span>🛑 Terminación por @(_dto.TerminationType == "Resignation" ? "Renuncia" : _dto.TerminationType == "UnfairDismissal" ? "Despido injustificado" : _dto.TerminationType == "JustifiedDismissal" ? "Despido justificado" : _dto.TerminationType == "MutualAgreement" ? "Mutuo acuerdo" : _dto.TerminationType == "Bankruptcy" ? "Quiebra" : _dto.TerminationType == "Death" ? "Fallecimiento" : "Período de prueba") (@(_dto.IsJustified == true ? "Justificado" : "No justificado"))</span>
                        }
                        |
                        📅 Efecto: @(_effectiveDate?.ToString("dd/MM/yyyy"))
                    </MudText>
                }
                <MudText Typo="Typo.body2" Color="Color.Error">
                    <b>🔒 NOTA:</b> Una vez que la acción pase a estado "Ejecutada", el registro será INMUTABLE.
                </MudText>
            </MudAlert>

            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="4">
                <MudStack Spacing="0" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                               Disabled="@(!_isFormValid)" OnClick="() => SaveActionAsync(false)">
                        💾 Guardar como Pendiente
                    </MudButton>
                    <MudText Typo="Typo.caption" Class="mt-1">(Requiere revisión posterior)</MudText>
                </MudStack>
                <MudStack Spacing="0" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                               Disabled="@(!CanExecuteNow)" OnClick="() => SaveActionAsync(true)">
                        ✅ Crear y Ejecutar Ahora
                    </MudButton>
                    <MudText Typo="Typo.caption" Class="mt-1">(Aplica el cambio a la BD ahora)</MudText>
                </MudStack>
            </MudStack>

        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    // ----- DTO EXTENDIDO -----
    private class ExtendedActionDto : CreatePersonalActionDto
    {
        public string? NewJobGradeName { get; set; }
        public string? NewContractTypeName { get; set; }
        public string? NewShiftName { get; set; }
        public string? NewCostCenterName { get; set; }
        public Guid? NewHealthProviderId { get; set; }
        public string? NewBankAccountNumber { get; set; }
        public string? NewBankName { get; set; }
        public string? NewHealthProviderName { get; set; } 
        public string? SuspensionType { get; set; }
        public DateTime? SuspensionStartDate { get; set; }
        public DateTime? SuspensionEndDate { get; set; }
        public string? TerminationType { get; set; }
        public bool? IsJustified { get; set; }
        public List<DocumentAttachmentDto> Documents { get; set; } = new();
     
        public int? NewBankId { get; set; }
    }

 
    

    private ExtendedActionDto _dto = new() { ActionType = "SalaryChange" };
    private MudForm? _form;
    private bool _isFormValid;
    private EmployeeSearchDto? _currentEmployee;
    private DateTime? _effectiveDate = DateTime.Today;
    private PeriodInfoDto? _periodInfo;

    private bool _hasCausalList = false;
    private List<string> _availableCausals = new();
    private List<UIDocumentRequirement> _requiredDocuments = new();
    private HashSet<string> _integrityErrors = new();

    private bool _hasSalaryError = false;
    private string _salaryErrorMessage = "";
    private decimal _minWageForEmployee = 0;
    private bool _isUploading = false;
    private Dictionary<string, UIDocumentRequirement> _tempDocMapping = new();

    private int _selectedBankId = 0; // 0 indica "ninguno seleccionado"
    private List<BankDto> _banksList = new();

    private bool CanExecuteNow =>
        _isFormValid &&
        !_hasSalaryError &&
        (_dto.Justification?.Length ?? 0) >= 20 &&
        _requiredDocuments.All(d => !d.IsMandatory || d.IsUploaded) &&
        !_integrityErrors.Any();

