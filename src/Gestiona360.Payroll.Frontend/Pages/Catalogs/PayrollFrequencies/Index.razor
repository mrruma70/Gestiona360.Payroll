@page "/catalogo/payroll-frequencies"
@attribute [Authorize]
@using System.Linq
@using System.Net.Http.Json
@using Gestiona360.Payroll.Application.Contracts.DTOs
@using Gestiona360.Payroll.Application.Contracts.Requests
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager _navManager


<MudText Typo="Typo.h6">Frecuencias de Pago</MudText>

<MudPaper Elevation="0" Class="pa-2 mb-4 d-flex align-center">
    <MudTooltip Text="Volver al Inicio">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => _navManager.NavigateTo("/"))" />
    </MudTooltip>
    <MudText Typo="Typo.h6" Class="ml-2">Panel de Administración</MudText>
</MudPaper>


@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="my-4" />
}
else
{
    <MudDataGrid T="PayrollFrequencyDto"
                 @ref="_grid"
                 Items="@PayrollList"
                 Hover="true"
                 Dense="true"
                 SortMode="SortMode.Single"
                 QuickFilter="@((Func<PayrollFrequencyDto, bool>)FilterFunc)"
                 RowsPerPage="10">

        <ToolBarContent>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenAddDrawer">➕ Nueva</MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="ExportToExcel"
                       Disabled="@_isExporting">
                @if (_isExporting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Generando...</span>
                }
                else
                {
                    <span>📊 Exportar a Excel</span>
                }
            </MudButton>
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Buscar..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="buscador-fijo ml-3"
                          Immediate="true"
                          Style="width: 300px;" />
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshDataAsync" />
        </ToolBarContent>

        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.Name" Title="Nombre" />
            <PropertyColumn Property="x => x.Code" Title="Código" />
            <PropertyColumn Property="x => x.DaysPerPeriod" Title="Días/Período" />
            <PropertyColumn Property="x => x.PeriodsPerYear" Title="Períodos/Año" />

            <PropertyColumn Property="x => x.IsActive" Title="Estado">
                <CellTemplate Context="cell">
                    <span class="@(cell.Item.IsActive ? "badge-active" : "badge-inactive")">
                        @(cell.Item.IsActive ? "Activo" : "Inactivo")
                    </span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.Id" Title="Acciones" Sortable="false" Filterable="false">
                <CellTemplate Context="cell">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   OnClick="@(() => OpenEditDrawer(cell.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => ConfirmDelete(cell.Item))" />
                </CellTemplate>
            </PropertyColumn>
        </Columns>

        <NoRecordsContent>
            <div class="empty-state">No hay frecuencias registradas.</div>
        </NoRecordsContent>

        <PagerContent>
            <MudDataGridPager PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudDataGrid>
}


<MudDrawer @bind-Open="_drawerOpen"
           Anchor="Anchor.Right"
           Variant="DrawerVariant.Temporary"
           Width="480px"
           Elevation="2">
    <div class="drawer-header">
        <h3>@(_isEditing ? "Editar frecuencia" : "Nueva frecuencia")</h3>
    </div>
    <div class="drawer-content">
        <MudForm @ref="mudForm">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_formModel.Name"
                                  Label="Nombre *"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Error="@(_fieldErrors.ContainsKey("Name"))"
                                  ErrorText="@(_fieldErrors.GetValueOrDefault("Name"))" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_formModel.Code"
                                  Label="Código *"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Error="@(_fieldErrors.ContainsKey("Code"))"
                                  ErrorText="@(_fieldErrors.GetValueOrDefault("Code"))" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_formModel.Description"
                                  Label="Descripción"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Multiline="true"
                                  Lines="3"
                                  Error="@(_fieldErrors.ContainsKey("Description"))"
                                  ErrorText="@(_fieldErrors.GetValueOrDefault("Description"))" />
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField @bind-Value="_formModel.DaysPerPeriod"
                                     Label="Días por período"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Error="@(_fieldErrors.ContainsKey("DaysPerPeriod"))"
                                     ErrorText="@(_fieldErrors.GetValueOrDefault("DaysPerPeriod"))" />
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField @bind-Value="_formModel.PeriodsPerYear"
                                     Label="Períodos por año"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Error="@(_fieldErrors.ContainsKey("PeriodsPerYear"))"
                                     ErrorText="@(_fieldErrors.GetValueOrDefault("PeriodsPerYear"))" />
                </MudItem>

                @if (_isEditing)
                {
                    <MudItem xs="12">
                        <MudSwitch T="bool"
                                   @bind-Checked="_formModel.IsActive"
                                   Label="Activo"
                                   Color="Color.Success" />
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </div>
    <div class="drawer-footer">
        <MudButton Variant="Variant.Outlined" OnClick="CloseDrawer">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSubmitting">
            @(_isSubmitting ? "Guardando..." : (_isEditing ? "Actualizar" : "Guardar"))
        </MudButton>
    </div>
</MudDrawer>

@if (_deleteDialogOpen)
{
    <MudOverlay Visible="true" DarkBackground="true">
        <MudPaper Class="pa-6" Style="width:400px; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:2000; background:#1E1E1E; border:1px solid #444; border-radius:12px;">
            <MudText Typo="Typo.h6" Style="color:#FFD54F; font-weight:700;">Confirmar eliminación</MudText>
            <MudText Class="mt-4" Style="color:#F5F5F5;">¿Desactivar "@_deleteTarget?.Name"?</MudText>
            <div class="d-flex justify-end mt-6 gap-3">
                <MudButton Variant="Variant.Text" OnClick="() => _deleteDialogOpen = false">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAsync">Desactivar</MudButton>
            </div>
        </MudPaper>
    </MudOverlay>
}



@code {
    [Inject] private IJSRuntime JS { get; set; }

    private MudDataGrid<PayrollFrequencyDto>? _grid;
    private List<PayrollFrequencyDto> PayrollList = new();
    private MudForm? mudForm;
    private bool _drawerOpen;
    private bool _isEditing;
    private bool _isSubmitting;
    private PayrollFrequencyFormModel _formModel = new();
    private bool _deleteDialogOpen;
    private PayrollFrequencyDto? _deleteTarget;
    private bool _isExporting = false;

    private Dictionary<string, string> _fieldErrors = new(StringComparer.OrdinalIgnoreCase);

    private bool _loading = true;
    private string _searchString = "";


    public class PayrollFrequencyFormModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Code { get; set; } = "";
        public string? Description { get; set; }
        public int DaysPerPeriod { get; set; }
        public int PeriodsPerYear { get; set; }
        public bool IsActive { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        PayrollList = await Http.GetFromJsonAsync<List<PayrollFrequencyDto>>("api/payrollfrequencies/all");
        PayrollList = PayrollList.OrderBy(x => x.Id).ToList();
        _loading = false;
    }


    private async Task RefreshDataAsync()
    {
        _loading = true;
        try
        {
            PayrollList = await Http.GetFromJsonAsync<List<PayrollFrequencyDto>>("api/payrollfrequencies/all") ?? new();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al actualizar la lista: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenAddDrawer()
    {
        _formModel = new PayrollFrequencyFormModel();
        _isEditing = false;
        _fieldErrors.Clear();
        _drawerOpen = true;
        mudForm?.ResetValidation();
    }

    private void OpenEditDrawer(PayrollFrequencyDto item)
    {
        _formModel = new PayrollFrequencyFormModel
        {
            Id = item.Id,
            Name = item.Name,
            Code = item.Code,
            Description = item.Description,
            DaysPerPeriod = item.DaysPerPeriod,
            PeriodsPerYear = item.PeriodsPerYear,
            IsActive = item.IsActive
        };
        _isEditing = true;
        _fieldErrors.Clear();
        _drawerOpen = true;
        mudForm?.ResetValidation();
    }

    private async Task SaveAsync()
    {
        await mudForm!.Validate();
        if (!mudForm.IsValid) return;

        _isSubmitting = true;
        _fieldErrors.Clear();

        try
        {
            HttpResponseMessage response;
            if (_isEditing)
            {
                var update = new UpdatePayrollFrequencyRequest
                {
                    Id = _formModel.Id,
                    Name = _formModel.Name.Trim(),
                    Code = _formModel.Code.Trim().ToUpper(),
                    DaysPerPeriod = _formModel.DaysPerPeriod,
                    PeriodsPerYear = _formModel.PeriodsPerYear,
                    Description = string.IsNullOrWhiteSpace(_formModel.Description) ? null : _formModel.Description,
                    IsActive = _formModel.IsActive
                };
                response = await Http.PutAsJsonAsync("api/payrollfrequencies", update);
            }
            else
            {
                var create = new CreatePayrollFrequencyRequest
                {
                    Name = _formModel.Name.Trim(),
                    Code = _formModel.Code.Trim().ToUpper(),
                    DaysPerPeriod = _formModel.DaysPerPeriod,
                    PeriodsPerYear = _formModel.PeriodsPerYear,
                    Description = string.IsNullOrWhiteSpace(_formModel.Description) ? null : _formModel.Description
                };
                response = await Http.PostAsJsonAsync("api/payrollfrequencies", create);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(_isEditing ? "Frecuencia actualizada" : "Frecuencia creada", Severity.Success);
                await RefreshTableData();
                CloseDrawer();
                return;
            }

            if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                mudForm!.ResetValidation();

                var jsonDoc = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonDocument>();
                var root = jsonDoc!.RootElement;

                if (root.TryGetProperty("errors", out var errorsProp))
                {
                    _fieldErrors.Clear();
                    foreach (var property in errorsProp.EnumerateObject())
                    {
                        var message = property.Value.EnumerateArray().FirstOrDefault().GetString();
                        if (!string.IsNullOrEmpty(message))
                        {
                            _fieldErrors[property.Name] = message;
                        }
                    }

                    StateHasChanged();
                }
            }
            else
            {
                Snackbar.Add("Ocurrió un error inesperado al procesar la solicitud.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de conexión o sistema: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ConfirmDelete(PayrollFrequencyDto item)
    {
        _deleteTarget = item;
        _deleteDialogOpen = true;
    }

    private async Task RefreshTableData()
    {
        var data = await Http.GetFromJsonAsync<List<PayrollFrequencyDto>>("api/payrollfrequencies/all");

        if (data != null)
        {
            PayrollList = data;
            StateHasChanged();
        }
    }


    private async Task DeleteAsync()
    {
        if (_deleteTarget == null) return;
        try
        {
            await Http.DeleteAsync($"api/payrollfrequencies/{_deleteTarget.Id}");
            Snackbar.Add("Desactivado", Severity.Success);
            await RefreshTableData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleteDialogOpen = false;
            _deleteTarget = null;
        }
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _formModel = new PayrollFrequencyFormModel();
        _fieldErrors.Clear();
        mudForm?.ResetValidation();
    }



    public class ValidationErrorResponse
    {
        public string Title { get; set; } = "";
        public Dictionary<string, string[]> Errors { get; set; } = new();
    }

    private async Task ExportToExcel()
    {
        _isExporting = true;
        StateHasChanged();

        try
        {
            var response = await Http.GetAsync("api/reports/payroll-frequencies?format=Excel");

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error del servidor: {error}", Severity.Error);
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);

            var fileName = $"Frecuencias_Pago_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            var mimeType = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";

            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, mimeType, fileName);

            Snackbar.Add("✅ Reporte generado y descargado exitosamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }


    private bool FilterFunc(PayrollFrequencyDto element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return element.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true ||
               element.Code?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true;
    }
}