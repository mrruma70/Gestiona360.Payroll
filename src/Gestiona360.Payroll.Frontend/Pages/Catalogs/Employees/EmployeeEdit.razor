@page "/employees/{id:guid}/edit"
@using Gestiona360.Payroll.Application.Contracts.DTOs
@using Gestiona360.Payroll.Application.Contracts.Requests
@using Gestiona360.Payroll.Application.Contracts.DTOs.Employees
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService

<PageTitle>Editar Empleado | Gestiona360</PageTitle>

@if (_isLoading)
{
    <div class="d-flex justify-center align-center" style="height: 50vh;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (_employee != null)
{
    <MudText Typo="Typo.h5" Class="mb-4">✏️ Editar Empleado: <strong>@_employee.FirstName @_employee.LastName</strong></MudText>
    @if (_isAdmin)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4" Icon="@Icons.Material.Filled.AdminPanelSettings">
            <MudText Typo="Typo.body2">
                <strong>🔓 Modo Administrador:</strong> Tiene permisos para modificar campos sensibles como la cédula de identidad.
                Cualquier cambio quedará registrado en el historial de auditoría.
            </MudText>
        </MudAlert>
    }
    <MudPaper Class="pa-4" Elevation="2">
        <MudForm @ref="_form" Model="_request">
            <MudGrid>
                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 1: IDENTIFICACIÓN (READONLY) *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">🪪 Identificación</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_request.Identification"
                                  ValueChanged="@((string v) => OnIdentificationChanged(v))"
                                  Label="🆔 Cédula"
                                  Variant="Variant.Outlined"
                                  ReadOnly="@(!_isAdmin)"
                                  Required="true"
                                  Validation="@(new Func<string, string?>(ValidateCedula))"
                                  HelperText="@(_isAdmin
                                                        ? "⚠️ Modo Admin: Puede modificar la cédula. Se validará formato y unicidad."
                                                        : "Solo lectura - Contacte a un administrador para cambios")"
                                  Color="@(_isAdmin ? Color.Warning : Color.Default)" />
                </MudItem>

                @if (_isAdmin && _cedulaModificada)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2" Icon="@Icons.Material.Filled.Warning">
                            <MudText Typo="Typo.body2">
                                <strong>⚠️ ATENCIÓN:</strong> La cédula fue modificada de
                                <strong>@_cedulaOriginal</strong> a <strong>@_request.Identification</strong>.
                                Esta acción es irreversible y quedará registrada en auditoría.
                            </MudText>
                        </MudAlert>
                    </MudItem>
                }

                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_employee.Code" Label="🏢 Código Empleado"
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 2: DATOS PERSONALES *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">👤 Datos Personales</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.FirstName" Label="Primer Nombre *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.SecondName" Label="Segundo Nombre"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.LastName" Label="Primer Apellido *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.SecondLastName" Label="Segundo Apellido"
                                  Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_request.BirthDate" Label="🎂 Fecha de Nacimiento"
                                   Variant="Variant.Outlined" MaxDate="DateTime.Today.AddYears(-15)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" @bind-Value="_request.Gender" Label="⚧ Sexo"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("M")">Masculino</MudSelectItem>
                        <MudSelectItem Value="@("F")">Femenino</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" @bind-Value="_request.MaritalStatus" Label="💍 Estado Civil"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("S")">Soltero/a</MudSelectItem>
                        <MudSelectItem Value="@("C")">Casado/a</MudSelectItem>
                        <MudSelectItem Value="@("U")">Unión libre</MudSelectItem>
                        <MudSelectItem Value="@("D")">Divorciado/a</MudSelectItem>
                        <MudSelectItem Value="@("V")">Viudo/a</MudSelectItem>
                    </MudSelect>
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 3: CONTACTO Y DOMICILIO *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">📞 Contacto y Domicilio</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.Email" Label="📧 Correo *"
                                  Variant="Variant.Outlined" Required="true"
                                  Validation="@(new Func<string, string?>(ValidateEmail))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.Phone" Label="☎️ Teléfono"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.MobilePhone" Label="📱 Celular *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_request.Address" Label="📍 Dirección"
                                  Variant="Variant.Outlined" Lines="2" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Value="_request.DepartmentId"
                               ValueChanged="@((int? v) => OnDepartmentChanged(v))"
                               Label="🗺️ Departamento"
                               Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="int?" Value="null">-- Seleccione --</MudSelectItem>
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem T="int?" Value="@d.Id">@d.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Value="_request.MunicipalityId"
                               ValueChanged="@((int? v) => { _request.MunicipalityId = v; StateHasChanged(); })"
                               Label="🏘️ Municipio"
                               Variant="Variant.Outlined" Clearable="true"
                               Disabled="@(!_request.DepartmentId.HasValue)">
                        <MudSelectItem T="int?" Value="null">-- Seleccione --</MudSelectItem>
                        @foreach (var m in _municipalities)
                        {
                            <MudSelectItem T="int?" Value="@m.Id">@m.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 4: CONTACTO DE EMERGENCIA *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">🚨 Contacto de Emergencia</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_request.EmergencyContactName" Label="👤 Nombre *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_request.EmergencyContactPhone" Label="📞 Teléfono *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_request.EmergencyContactRelationship" Label="👨‍👩‍👧 Parentesco *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 5: DATOS FISCALES *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">🏛️ Datos Fiscales</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.NORUC" Label="🏛️ N° RUC *"
                                  Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.NOINSS" Label="🏥 N° INSS *"
                                  Required="true" Variant="Variant.Outlined" />
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 6: ASIGNACIÓN LABORAL *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">💼 Asignación Laboral</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" @bind-Value="_request.BranchId" Label="🏙️ Sucursal *"
                               Variant="Variant.Outlined" Required="true">
                        @foreach (var branch in _branches)
                        {
                            <MudSelectItem T="Guid" Value="@branch.Id">@branch.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" @bind-Value="_request.PayrollGroupId"
                               Label="💼 Grupo de Nómina *"
                               Variant="Variant.Outlined" Required="true">
                        @foreach (var pg in _payrollGroups)
                        {
                            <MudSelectItem T="Guid" Value="@pg.Id">@pg.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int" @bind-Value="_request.ContractTypeId" Label="📄 Tipo Contrato *"
                               Variant="Variant.Outlined" Required="true">
                        @foreach (var ct in _contractTypes)
                        {
                            <MudSelectItem T="int" Value="@ct.Id">@ct.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     Value="_request.BaseSalary"
                                     ValueChanged="@((decimal v) => OnSalaryChanged(v))"
                                     Label="💰 Salario Base (C$) *"
                                     Variant="Variant.Outlined" Required="true"
                                     Min="0m" Step="100m" Format="N2" />
                </MudItem>

                @if (_showMinSalaryWarning)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Error" Dense="true">
                            ⛔ El salario debe ser ≥ C$ @_minSalaryRequired.ToString("N2") (mínimo legal del sector)
                        </MudAlert>
                    </MudItem>
                }

                @* ═══════════════════════════════════════════════════════════════ *@
                @* CAMPOS READONLY gestionados por Acciones de Personal *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2 mb-2">
                        <MudText Typo="Typo.body2">
                            <strong>⚠️ Nota:</strong> Los campos <strong>Puesto, Proveedor de Salud, Centro de Costo y Datos Bancarios</strong>
                            se gestionan mediante <strong>Acciones de Personal</strong> y no pueden editarse aquí.
                        </MudText>
                    </MudAlert>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Value="@(_selectedJobGrade != null ? $"{_selectedJobGrade.JobPositionName} - {_selectedJobGrade.Name}" : "Sin puesto")"
                                  Label="👔 Puesto / Nivel"
                                  Variant="Variant.Outlined" ReadOnly="true"
                                  HelperText="Gestionado por Acción de Personal: PositionChange" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@(_selectedHealthProvider?.Name ?? "Sin proveedor")"
                                  Label="🏥 Proveedor Salud"
                                  Variant="Variant.Outlined" ReadOnly="true"
                                  HelperText="Gestionado por Acción de Personal: HealthProviderChange" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@(_selectedCostCenter != null ? $"{_selectedCostCenter.Code} - {_selectedCostCenter.Name}" : "Sin asignar")"
                                  Label="🏢 Centro de Costo"
                                  Variant="Variant.Outlined" ReadOnly="true"
                                  HelperText="Gestionado por Acción de Personal: CostCenterChange" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@(_selectedBank?.Name ?? "Sin cuenta")"
                                  Label="🏦 Banco"
                                  Variant="Variant.Outlined" ReadOnly="true"
                                  HelperText="Gestionado por Acción de Personal: BankAccountChange" />
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 7: CONDICIONES ESPECIALES *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">⚙️ Condiciones Especiales</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudCheckBox @bind-Value="_request.IsTrustEmployee"
                                 Label="Empleado de Confianza (Art. 44)"
                                 Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudCheckBox @bind-Value="_request.UsesTimeClock"
                                 Label="Usa Reloj de Marcas"
                                 Color="Color.Info" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal?" @bind-Value="_request.BenefitsInKindValue"
                                     Label="💼 Valor Beneficios en Especie (C$)"
                                     Variant="Variant.Outlined" Format="N2" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_request.BenefitsInKindDescription"
                                  Label="📝 Descripción Beneficios"
                                  Variant="Variant.Outlined" />
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 8: TRABAJADOR EXTRANJERO *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">🌍 Trabajador Extranjero (Opcional)</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_request.Nationality"
                                  Label="Nacionalidad"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_request.WorkPermitNumber"
                                  Label="N° Permiso de Trabajo"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_request.WorkPermitExpirationDate"
                                   Label="Vencimiento Permiso"
                                   Variant="Variant.Outlined" />
                </MudItem>

                @* ═══════════════════════════════════════════════════════════════ *@
                @* SECCIÓN 9: ESTADO Y NOTAS *@
                @* ═══════════════════════════════════════════════════════════════ *@
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">⚙️ Estado</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSwitch T="bool" @bind-Value="_request.IsActive"
                               Label="Empleado Activo" Color="Color.Success" />
                </MudItem>

                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">📝 Notas y Observaciones</MudText>
                    <MudDivider Class="mb-3" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_request.Notes"
                                  Label="Notas / Observaciones"
                                  Variant="Variant.Outlined" Lines="3" />
                </MudItem>

                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Class="mt-4">
                        <MudText Typo="Typo.body2">
                            <strong>ℹ️ Nota:</strong> Los cambios de Estado (Suspensión, Terminación), Período de Prueba, Puesto, Proveedor de Salud, Centro de Costo y Datos Bancarios se gestionan mediante el módulo de <strong>"Acciones de Personal"</strong>.
                        </MudText>
                    </MudAlert>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>

    <!-- BOTONES DE ACCIÓN -->
    <div class="d-flex justify-space-between mt-4">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="Cancel">
            Cancelar
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SubmitAsync" Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Guardando...</span>
            }
            else
            {
                <span>💾 Guardar Cambios</span>
            }
        </MudButton>
    </div>
}
else
{
    <MudAlert Severity="Severity.Error">No se encontró el empleado.</MudAlert>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private bool _isSubmitting = false;
    private bool _showMinSalaryWarning = false;
    private decimal _minSalaryRequired = 0;

    private MudForm? _form;
    private EmployeeDetailDto? _employee;
    private UpdateEmployeeRequest _request = new();

    // ✅ Catálogos
    private List<BranchDto> _branches = new();
    private List<ContractTypeDto> _contractTypes = new();
    private List<JobGradeDto> _jobGrades = new();
    private List<HealthProviderDto> _healthProviders = new();
    private List<BankDto> _banks = new();
    private List<CostCenterDto> _costCenters = new();
    private List<PayrollGroupDto> _payrollGroups = new();
    private List<DepartmentDto> _departments = new();
    private List<MunicipalityDto> _municipalities = new();

    // ✅ Variables para mostrar valores en campos readonly
    private JobGradeDto? _selectedJobGrade;
    private HealthProviderDto? _selectedHealthProvider;
    private BankDto? _selectedBank;
    private CostCenterDto? _selectedCostCenter;

    // ✅  Control de permisos y cédula
    private bool _isAdmin = false; // si es true Fuerza el modo administrador para pruebas
    private bool _cedulaModificada = false;
    private string _cedulaOriginal = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // ═══════════════════════════════════════════════════════════════
        // VERIFICAR ROL DEL USUARIO
        // ═══════════════════════════════════════════════════════════════
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _isAdmin = user.IsInRole("Admin") || user.IsInRole("Administrator");
        }
        catch
        {
            _isAdmin = false;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            // ═══════════════════════════════════════════════════════════════
            // PASO 1: Cargar catálogos básicos
            // ═══════════════════════════════════════════════════════════════
            _branches = await Http.GetFromJsonAsync<List<BranchDto>>("api/branches/active") ?? new();
            _contractTypes = await Http.GetFromJsonAsync<List<ContractTypeDto>>("api/contracttypes/all") ?? new();
            _jobGrades = await Http.GetFromJsonAsync<List<JobGradeDto>>("api/jobgrades/active") ?? new();
            _healthProviders = await Http.GetFromJsonAsync<List<HealthProviderDto>>("api/healthproviders/active") ?? new();
            _banks = await Http.GetFromJsonAsync<List<BankDto>>("api/banks/active") ?? new();
            _costCenters = await Http.GetFromJsonAsync<List<CostCenterDto>>("api/costcenters/active") ?? new();
            _payrollGroups = await Http.GetFromJsonAsync<List<PayrollGroupDto>>("api/payrollgroups/active") ?? new();
            _departments = await Http.GetFromJsonAsync<List<DepartmentDto>>("api/departments/active") ?? new();

            // ═══════════════════════════════════════════════════════════════
            // PASO 2: Cargar el empleado
            // ═══════════════════════════════════════════════════════════════
            var response = await Http.GetAsync($"api/employees/{Id}");
            if (response.IsSuccessStatusCode)
            {
                _employee = await response.Content.ReadFromJsonAsync<EmployeeDetailDto>();

                if (_employee != null)
                {
                    // ═══════════════════════════════════════════════════════════════
                    // PASO 3: Si el empleado tiene departamento, cargar sus municipios
                    // ═══════════════════════════════════════════════════════════════
                    if (_employee.DepartmentId.HasValue)
                    {
                        try
                        {
                            _municipalities = await Http.GetFromJsonAsync<List<MunicipalityDto>>(
                                $"api/municipalities/by-department/{_employee.DepartmentId}") ?? new();
                        }
                        catch (Exception ex)
                        {
                            Snackbar.Add($"⚠️ Error cargando municipios: {ex.Message}", Severity.Warning);
                            _municipalities = new();
                        }
                    }

                    // ═══════════════════════════════════════════════════════════════
                    // PASO 4: Mapear datos del empleado al request
                    // ═══════════════════════════════════════════════════════════════
                    _request = new UpdateEmployeeRequest
                    {
                        Id = _employee.Id,

                        // Datos personales
                        FirstName = _employee.FirstName,
                        SecondName = _employee.SecondName,
                        LastName = _employee.LastName,
                        SecondLastName = _employee.SecondLastName,
                        BirthDate = _employee.BirthDate,
                        Gender = _employee.Gender,
                        MaritalStatus = _employee.MaritalStatus,

                        // Contacto
                        Email = _employee.Email,
                        Phone = _employee.Phone,
                        MobilePhone = _employee.MobilePhone,

                        // Domicilio
                        Address = _employee.Address,
                        DepartmentId = _employee.DepartmentId,
                        MunicipalityId = _employee.MunicipalityId,

                        // Contacto emergencia
                        EmergencyContactName = _employee.EmergencyContactName,
                        EmergencyContactPhone = _employee.EmergencyContactPhone,
                        EmergencyContactRelationship = _employee.EmergencyContactRelationship,

                        // Datos fiscales
                        NORUC = _employee.NORUC ?? string.Empty,
                        NOINSS = _employee.NOINSS ?? string.Empty,

                        // Asignación laboral
                        BranchId = _employee.BranchId,
                        PayrollGroupId = _employee.PayrollGroupId,
                        ContractTypeId = _employee.ContractTypeId ?? 0,
                        BaseSalary = _employee.BaseSalary,

                        // Condiciones especiales
                        IsTrustEmployee = _employee.IsTrustEmployee,
                        UsesTimeClock = _employee.UsesTimeClock,
                        BenefitsInKindValue = _employee.BenefitsInKindValue,
                        BenefitsInKindDescription = _employee.BenefitsInKindDescription,

                        // Trabajador extranjero
                        Nationality = _employee.Nationality,
                        WorkPermitNumber = _employee.WorkPermitNumber,
                        WorkPermitExpirationDate = _employee.WorkPermitExpirationDate,

                        // Bancario
                        BankBeneficiaryName = _employee.BankBeneficiaryName,

                        // Estado y notas
                        IsActive = _employee.IsActive,
                        Notes = _employee.Notes,

                        // Período de prueba
                        ProbationStartDate = _employee.ProbationStartDate,
                        ProbationEndDate = _employee.ProbationEndDate
                    };

                    // ═══════════════════════════════════════════════════════════════
                    // PASO 5: Cargar valores para campos readonly
                    // ═══════════════════════════════════════════════════════════════
                    _selectedJobGrade = _jobGrades.FirstOrDefault(jg => jg.Id == _employee.JobGradeId);
                    _selectedHealthProvider = _healthProviders.FirstOrDefault(hp => hp.Id == _employee.HealthProviderId);
                    _selectedBank = _banks.FirstOrDefault(b => b.Id == _employee.BankId);
                    _selectedCostCenter = _costCenters.FirstOrDefault(cc => cc.Id == _employee.CostCenterId);

                    // Validar salario mínimo inicial
                    if (_selectedJobGrade != null)
                    {
                        _minSalaryRequired = _selectedJobGrade.MinWageNIO;
                        OnSalaryChanged(_employee.BaseSalary);
                    }
                }
            }
            else
            {
                Snackbar.Add("❌ Error al cargar datos del empleado", Severity.Error);
                Navigation.NavigateTo("/employees");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnDepartmentChanged(int? departmentId)
    {
        _request.DepartmentId = departmentId;
        _request.MunicipalityId = null;
        _municipalities.Clear();

        if (departmentId.HasValue)
        {
            try
            {
                _municipalities = await Http.GetFromJsonAsync<List<MunicipalityDto>>(
                    $"api/municipalities/by-department/{departmentId}") ?? new();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"⚠️ Error cargando municipios: {ex.Message}", Severity.Warning);
                _municipalities = new();
            }
        }

        StateHasChanged();
    }

    private void OnIdentificationChanged(string newCedula)
    {
        if (string.IsNullOrWhiteSpace(newCedula))
        {
            _request.Identification = newCedula;
            _cedulaModificada = false;
            StateHasChanged();
            return;
        }

        _request.Identification = newCedula;

        // Detectar si cambió respecto al original
        _cedulaModificada = !string.Equals(
            newCedula.Trim(),
            _cedulaOriginal.Trim(),
            StringComparison.OrdinalIgnoreCase);

        StateHasChanged();
    }

    private void OnSalaryChanged(decimal salary)
    {
        _request.BaseSalary = salary;
        _showMinSalaryWarning = salary < _minSalaryRequired && _minSalaryRequired > 0;
        StateHasChanged();
    }

    private string ValidateEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "El correo es requerido";
        if (!System.Text.RegularExpressions.Regex.IsMatch(value, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            return "Correo inválido";
        return null;
    }

    private string ValidateCedula(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "La cédula es obligatoria.";

        // Validación matemática estricta
        if (!Gestiona360.Payroll.Application.Contracts.Common.Validators.CedulaValidator.EsValida(value))
            return "La cédula no es válida. Verifique el formato y el dígito verificador (letra final).";

        return null; // Es válida
    }

    private async Task SubmitAsync()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_form.IsValid || _showMinSalaryWarning)
            {
                Snackbar.Add("⚠️ Complete todos los campos requeridos correctamente", Severity.Warning);
                return;
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // CONFIRMACIÓN SI SE MODIFICÓ LA CÉDULA
        // ═══════════════════════════════════════════════════════════════
        if (_cedulaModificada)
        {
            bool? confirmado = await DialogService.ShowMessageBox(
                "⚠️ Confirmar cambio de cédula",
                $"Está a punto de modificar la cédula del empleado.\n\n" +
                $"Cédula anterior: {_cedulaOriginal}\n" +
                $"Cédula nueva: {_request.Identification}\n\n" +
                $"Esta acción quedará registrada en auditoría. ¿Desea continuar?",
                yesText: "Sí, continuar",
                noText: "Cancelar");

            if (confirmado != true)
                return;
        }


        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var response = await Http.PutAsJsonAsync($"api/employees/{Id}", _request);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Empleado actualizado exitosamente", Severity.Success);
                Navigation.NavigateTo($"/employees/{Id}");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private void Cancel() => Navigation.NavigateTo($"/employees/{Id}");

