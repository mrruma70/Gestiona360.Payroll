@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">📥 Importación Masiva - Acuerdo MITRAB</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">⚙️ Seleccione la Estrategia de Carga:</MudText>
                <MudRadioGroup @bind-Value="_selectedStrategy" T="int">
                    <MudRadio Value="0" Color="Color.Primary" Dense="true">
                        <strong>Solo Actualizar (Merge):</strong> Modifica montos existentes y añade nuevos sectores.
                    </MudRadio>
                    <MudRadio Value="1" Color="Color.Error" Dense="true" Class="mt-2">
                        <strong>Borrar e Importar desde cero:</strong> Limpia completamente la matriz antes de la carga.
                    </MudRadio>
                </MudRadioGroup>
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-2" />
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">📄 Archivo de Datos (.csv):</MudText>

                <!-- InputFile oculto -->
                <InputFile OnChange="@OnFileSelected" accept=".csv" id="mitrabFileInput" style="display: none;" />

                <!-- MudButton que dispara el clic en el InputFile mediante eval() -->
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.CloudUpload"
                           OnClick="TriggerFilePicker">
                    @(_file == null ? "Seleccionar CSV Oficial" : _file.Name)
                </MudButton>

                @if (_file != null)
                {
                    <MudText Typo="Typo.caption" Class="mt-2" Style="color: green;">
                        ✓ Archivo listo para procesar (@((_file.Size / 1024.0).ToString("F2")) KB)
                    </MudText>
                }
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton Color="@GetSubmitButtonColor()"
                   Variant="Variant.Filled"
                   Disabled="@(_file == null || _isProcessing)"
                   OnClick="SubmitAsync">
            @if (_isProcessing)
            {
                <MudProgressCircular Class="ms-n1 me-1" Size="Size.Small" Indeterminate="true" />
                <span>Procesando...</span>
            }
            else
            {
                <span>🚀 Ejecutar Carga</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    private bool _isProcessing = false;
    private IBrowserFile? _file;
    private int _selectedStrategy = 0;

    private async Task TriggerFilePicker()
    {
        // Usamos eval() para hacer clic en el InputFile oculto.
        // Esta función siempre está disponible en el navegador.
        await JS.InvokeVoidAsync("eval", "document.getElementById('mitrabFileInput').click()");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            _file = file;
            Snackbar.Add($"✓ Archivo seleccionado: {file.Name}", Severity.Info);
        }
        else
        {
            _file = null;
            Snackbar.Add("❌ El archivo debe tener extensión .csv", Severity.Error);
        }
        await InvokeAsync(StateHasChanged);
    }

    private Color GetSubmitButtonColor()
    {
        return _selectedStrategy == 1 ? Color.Error : Color.Primary;
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitAsync()
    {
        if (_file == null) return;

        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var content = new MultipartFormDataContent();
            var fileStream = _file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("text/csv");
            content.Add(streamContent, "file", _file.Name);
            content.Add(new StringContent(_selectedStrategy.ToString()), "strategy");

            var response = await Http.PostAsync("api/employees/mitrab-salaries/import", content);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Acuerdo de salarios mínimos MITRAB ejecutado con éxito.", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error: {errorMsg}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"⚠️ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}