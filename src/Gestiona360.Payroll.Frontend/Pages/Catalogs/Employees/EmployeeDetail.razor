                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.PictureAsPdf">
                                La credencial se imprime en tamaño tipo gafete (10cm x 7cm)
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Security">
                                El QR contiene un código único que valida al empleado
                            </MudListItem>
                        </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudTabPanel>

    </MudTabs>
}
else
{
    <MudAlert Severity="Severity.Error">No se encontró el empleado.</MudAlert>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private EmployeeDetailDto? _employee;
    private string? _qrBase64; 
    private string? _qrError;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeeDetail();
    }

    private async Task LoadEmployeeDetail()
    {
        _isLoading = true;
        try
        {
            var response = await Http.GetAsync($"api/employees/{Id}");
            if (response.IsSuccessStatusCode)
            {
                _employee = await response.Content.ReadFromJsonAsync<EmployeeDetailDto>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Snackbar.Add("❌ Empleado no encontrado", Severity.Error);
                Navigation.NavigateTo("/employees");
                return;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error al cargar: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error de conexión: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void GoBack() => Navigation.NavigateTo("/employees");
    private void EditEmployee() => Navigation.NavigateTo($"/employees/{Id}/edit");

    private async Task PrintFicha()
    {
        try
        {
            var response = await Http.GetAsync($"api/employees/{Id}/pdf");
            if (response.IsSuccessStatusCode)
            {
                var pdfBytes = await response.Content.ReadAsByteArrayAsync();
                var base64String = Convert.ToBase64String(pdfBytes);
                var fileName = $"Ficha_Empleado_{_employee?.Identification ?? Id.ToString()}.pdf";
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64String, "application/pdf", fileName);
                Snackbar.Add("🖨️ Ficha descargada exitosamente", Severity.Success);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error al generar PDF: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error de conexión: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e, string docType)
    {
        var file = e.File;
        if (file == null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            Snackbar.Add("❌ El archivo es demasiado grande. Máximo 5MB.", Severity.Error);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var fileContent = memoryStream.ToArray();

            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(fileContent), "file", file.Name);

            string endpoint = docType switch
            {
                "photo" => $"api/employees/{Id}/documents/photo",
                "id-front" => $"api/employees/{Id}/documents/id-front",
                "id-back" => $"api/employees/{Id}/documents/id-back",
                _ => throw new ArgumentException("Tipo de documento no válido")
            };

            var response = await Http.PostAsync(endpoint, content);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Documento subido exitosamente", Severity.Success);
                await LoadEmployeeDetail();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error al subir: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task ClearDocument(string propertyName)
    {
        bool? confirmed = await dialogService.ShowMessageBox(
            "⚠️ Confirmar eliminación",
            "¿Está seguro de eliminar este documento? Esta acción no se puede deshacer.",
            yesText: "Sí, eliminar", noText: "Cancelar");

        if (confirmed == true)
        {
            try
            {
                string routeType = propertyName switch
                {
                    "PhotoUrl" => "photo",
                    "IdFrontUrl" => "id-front",
                    "IdBackUrl" => "id-back",
                    _ => throw new ArgumentException("Tipo de documento no válido")
                };

                var response = await Http.DeleteAsync($"api/employees/{Id}/documents/{routeType}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("✅ Documento eliminado exitosamente", Severity.Success);
                    await LoadEmployeeDetail();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"❌ Error al eliminar: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"❌ Error de conexión: {ex.Message}", Severity.Error);
            }
        }
    }

    // ═══════════════════════════════════════════════════════════════
    // MÉTODOS HELPER
    // ═══════════════════════════════════════════════════════════════

    private string GetInitials(string firstName, string lastName)
    {
        var f = string.IsNullOrEmpty(firstName) ? "" : firstName.Substring(0, 1).ToUpper();
        var l = string.IsNullOrEmpty(lastName) ? "" : lastName.Substring(0, 1).ToUpper();
        return $"{f}{l}";
    }

    private string GetFullImageUrl(string? relativeUrl)
    {
        if (string.IsNullOrEmpty(relativeUrl)) return "";
        if (relativeUrl.StartsWith("http")) return relativeUrl;
        var apiBase = Config["ApiBaseUrl"] ?? "https://localhost:7119";
        return $"{apiBase.TrimEnd('/')}{relativeUrl}";
    }

    private Color GetStatusColor(string? status) => status switch
    {
        "Active" => Color.Success,
        "Suspended" => Color.Warning,
        "Terminated" => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(string? status) => status switch
    {
        "Active" => "✅ Activo",
        "Suspended" => "⏸️ Suspendido",
        "Terminated" => "⏹️ Terminado",
        _ => "❓ Desconocido"
    };

    private string GetGenderText(string? gender) => gender switch
    {
        "M" => "Masculino",
        "F" => "Femenino",
        _ => "No especificado"
    };

    private string GetMaritalStatusText(string? status) => status switch
    {
        "S" => "Soltero/a",
        "C" => "Casado/a",
        "U" => "Unión libre",
        "D" => "Divorciado/a",
        "V" => "Viudo/a",
        _ => "No especificado"
    };

    private string GetAntiguedad(DateTime hireDate)
    {
        var now = DateTime.Now;
        var years = now.Year - hireDate.Year;
        var months = now.Month - hireDate.Month;
        if (months < 0) { years--; months += 12; }
        if (years > 0) return $"{years} año{(years > 1 ? "s" : "")}, {months} mes{(months != 1 ? "es" : "")}";
        if (months > 0) return $"{months} mes{(months > 1 ? "es" : "")}";
        return "Recién ingresado";
    }

    private async Task PrintCredential()
    {
        try
        {
            var response = await Http.GetAsync($"api/employees/{Id}/credential-pdf");
            if (response.IsSuccessStatusCode)
            {
                var pdfBytes = await response.Content.ReadAsByteArrayAsync();
                var base64String = Convert.ToBase64String(pdfBytes);
                var fileName = $"Credencial_{_employee?.Code ?? Id.ToString()}.pdf";

                await JS.InvokeVoidAsync("downloadFileFromBase64", base64String, "application/pdf", fileName);
                Snackbar.Add("🖨️ Credencial descargada exitosamente", Severity.Success);
            }
            else
            {
                Snackbar.Add("❌ Error al generar la credencial", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _employee != null)
        {
            // 1. Cargar el QR como base64
            await LoadQrCodeAsync();

            // 2. Generar el código de barras con JsBarcode
            await GenerateBarcodeAsync();
        }
    }

    // ✅ MÉTODO NUEVO: Cargar QR desde el backend
    private async Task LoadQrCodeAsync()
    {
        try
        {
            Console.WriteLine($"🔍 Intentando cargar QR para empleado {Id}");

            var response = await Http.GetAsync($"api/employees/{Id}/qrcode");

            Console.WriteLine($"📡 Respuesta del servidor: {(int)response.StatusCode} {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                var qrBytes = await response.Content.ReadAsByteArrayAsync();
                Console.WriteLine($"✅ QR recibido: {qrBytes.Length} bytes");

                var base64String = Convert.ToBase64String(qrBytes);
                _qrBase64 = $"data:image/png;base64,{base64String}";
                _qrError = null;
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _qrError = $"Error {(int)response.StatusCode}: {errorContent}";
                Console.WriteLine($"❌ Error cargando QR: {_qrError}");
            }
        }
        catch (Exception ex)
        {
            _qrError = $"Error de conexión: {ex.Message}";
            Console.WriteLine($"❌ Excepción cargando QR: {ex.Message}");
        }

        StateHasChanged();
    }

    // ✅ MÉTODO NUEVO: Generar código de barras con JsBarcode
    private async Task GenerateBarcodeAsync()
    {
        try
        {
            Console.WriteLine($"🔍 Intentando generar código de barras para {Id}");

            var response = await Http.GetFromJsonAsync<BarcodePayloadResponse>($"api/employees/{Id}/barcode-payload");

            if (response != null && !string.IsNullOrEmpty(response.payload))
            {
                Console.WriteLine($"✅ Payload recibido: {response.payload}");

                var elementId = $"barcode-{Id.ToString("N")}";
                Console.WriteLine($"🎯 ID del elemento SVG: #{elementId}");

                // Llamar a la función JavaScript global
                var success = await JS.InvokeAsync<bool>("generateBarcode", elementId, response.payload);

                if (success)
                {
                    Console.WriteLine("✅ Código de barras generado correctamente");
                }
                else
                {
                    Console.WriteLine("❌ La función JS retornó false");
                    Snackbar.Add("⚠️ No se pudo generar el código de barras", Severity.Warning);
                }
            }
            else
            {
                Console.WriteLine("❌ No se recibió payload del backend");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error generando código de barras: {ex.Message}");
            Snackbar.Add($"⚠️ Error código barras: {ex.Message}", Severity.Warning);
        }
    }


    private async Task DownloadQrCode()
    {
        try
        {
            var response = await Http.GetAsync($"api/employees/{Id}/qrcode");
            if (response.IsSuccessStatusCode)
            {
                var qrBytes = await response.Content.ReadAsByteArrayAsync();
                var base64String = Convert.ToBase64String(qrBytes);
                var fileName = $"QR_{_employee?.Code ?? Id.ToString()}.png";

                await JS.InvokeVoidAsync("downloadFileFromBase64", base64String, "image/png", fileName);
                Snackbar.Add("📥 Código QR descargado exitosamente", Severity.Success);
            }
            else
            {
                Snackbar.Add("❌ Error al descargar el QR", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
    }

    // ✅ MÉTODO SIMPLE: Obtener URL completa del API
    private string GetApiUrl(string endpoint)
    {
        var apiBase = Config["ApiBaseUrl"] ?? "https://localhost:7119";
        return $"{apiBase.TrimEnd('/')}{endpoint}";
    }

    // ✅ MÉTODO SIMPLE: URL de API pública para código de barras
    private string GetBarcodeApiUrl(string code)
    {
        // Usamos API gratuita de TEC-IT (no requiere registro)
        return $"https://barcode.tec-it.com/barcode.ashx?data={Uri.EscapeDataString(code)}&code=Code128&multibar=1&width=300&height=100&dpi=96&imagetype=Png&rotation=0&color=%23000000&bgcolor=%23ffffff&qunit=Mm&quiet=0";
    }


    private class BarcodePayloadResponse
    {
        public string payload { get; set; } = string.Empty;
    }
