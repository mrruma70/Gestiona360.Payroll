@page "/employees/{id:guid}"
@using Gestiona360.Payroll.Application.Contracts.DTOs.Employees
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Config
@inject IDialogService dialogService

<PageTitle>Ficha del Empleado | Gestiona360</PageTitle>

@if (_isLoading)
{
    <div class="d-flex justify-center align-center" style="height: 50vh;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (_employee != null)
{
    @* ═══════════════════════════════════════════════════════════════ *@
    @* ENCABEZADO MEJORADO *@
    @* ═══════════════════════════════════════════════════════════════ *@
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.h5" Class="mb-2">
                    👤 <strong>@_employee.FirstName @(_employee.SecondName) @_employee.LastName @(_employee.SecondLastName)</strong>
                </MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    @_employee.JobPositionName - @_employee.JobGradeName
                </MudText>
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_employee.EmploymentStatus)">
                        @GetStatusText(_employee.EmploymentStatus)
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                        🆔 @_employee.Identification
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        🏢 @_employee.Code
                    </MudChip>
                    @if (_employee.IsOnProbation)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                            ⏳ En Período de Prueba
                        </MudChip>
                    }
                    @if (_employee.UsesTimeClock)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">
                            ⏰ Usa Reloj de Marcas
                        </MudChip>
                    }
                    @if (_employee.PreviousEmployeeId.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                            🔄 Reingreso
                        </MudChip>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex align-center justify-end">
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack">
                        Volver
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="EditEmployee">
                        ✏️ Editar
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintFicha">
                        🖨️ PDF
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTabs Elevation="1" Rounded="true" Border="true" ApplyEffectsToContainer="true">

        @* ═══════════════════════════════════════════════════════════════ *@
        @* PESTAÑA 1: RESUMEN Y DATOS PERSONALES *@
        @* ═══════════════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Resumen" Icon="@Icons.Material.Filled.Person">
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0">
                        @if (!string.IsNullOrEmpty(_employee.PhotoUrl))
                        {
                            <img src="@GetFullImageUrl(_employee.PhotoUrl)"
                                 alt="Foto de perfil"
                                 style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--mud-palette-primary);"
                                 class="mb-3" />
                        }
                        else
                        {
                            <MudAvatar Size="Size.Large" Color="Color.Primary" Class="mb-3" Style="width: 120px; height: 120px; font-size: 3rem;">
                                @GetInitials(_employee.FirstName, _employee.LastName)
                            </MudAvatar>
                        }

                        <MudText Typo="Typo.h6" Align="Align.Center">
                            @_employee.FirstName @_employee.LastName
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            @_employee.JobPositionName
                        </MudText>

                        <MudDivider Class="my-3" />

                        <InputFile id="photoUpload" style="display: none;"
                                   OnChange="@(e => HandleFileUpload(e, "photo"))"
                                   accept="image/*" />
                        <label for="photoUpload" class="mud-button-root mud-button-outlined mud-button-outlined-primary mud-button-outlined-size-small mud-ripple mb-3"
                               style="cursor: pointer; padding: 6px 16px;">
                            📷 Cambiar Foto
                        </label>

                        <MudDivider Class="my-2" />

                        <MudText Typo="Typo.body2" Class="mt-2"><strong>🎂 Nacimiento:</strong> @(_employee.BirthDate?.ToString("dd/MM/yyyy") ?? "N/A")</MudText>
                        <MudText Typo="Typo.body2"><strong>⚧ Sexo:</strong> @GetGenderText(_employee.Gender)</MudText>
                        <MudText Typo="Typo.body2"><strong>💍 Estado Civil:</strong> @GetMaritalStatusText(_employee.MaritalStatus)</MudText>
                        <MudText Typo="Typo.body2"><strong>📅 Ingreso:</strong> @_employee.HireDate.ToString("dd/MM/yyyy")</MudText>
                        @if (_employee.FirstHireDate.HasValue && _employee.FirstHireDate != _employee.HireDate)
                        {
                            <MudText Typo="Typo.body2"><strong>📅 Primer Ingreso:</strong> @_employee.FirstHireDate.Value.ToString("dd/MM/yyyy")</MudText>
                        }
                        <MudText Typo="Typo.body2"><strong>⏳ Antigüedad:</strong> @GetAntiguedad(_employee.FirstHireDate ?? _employee.HireDate)</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="8">
                    @* ── Contacto ── *@
                    <MudPaper Class="pa-4 mb-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">📞 Información de Contacto</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.Email" Label="📧 Correo Electrónico" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.Phone" Label="☎️ Teléfono" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.MobilePhone ?? "N/A")" Label="📱 Celular" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    @* ── Domicilio ── *@
                    <MudPaper Class="pa-4 mb-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🏠 Domicilio</MudText>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField Value="@(_employee.Address ?? "No registrada")" Label="📍 Dirección" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.DepartmentName ?? "N/A")" Label="🗺️ Departamento" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.MunicipalityName ?? "N/A")" Label="🏘️ Municipio" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    @* ── Contacto de Emergencia ── *@
                    <MudPaper Class="pa-4 mb-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🚨 Contacto de Emergencia</MudText>
                        @if (!string.IsNullOrEmpty(_employee.EmergencyContactName))
                        {
                            <MudGrid>
                                <MudItem xs="12" sm="4">
                                    <MudTextField Value="@_employee.EmergencyContactName" Label="👤 Nombre" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTextField Value="@(_employee.EmergencyContactPhone ?? "N/A")" Label="📞 Teléfono" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTextField Value="@(_employee.EmergencyContactRelationship ?? "N/A")" Label="👨‍👩‍👧 Parentesco" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                <MudText Typo="Typo.body2">⚠️ No hay contacto de emergencia registrado. Actualice el empleado para agregarlo.</MudText>
                            </MudAlert>
                        }
                    </MudPaper>

                    @* ── Asignación Laboral ── *@
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">💼 Asignación Laboral</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.BranchName" Label="🏙️ Sucursal" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.PayrollGroupName ?? "No asignado")"
                                              Label="💼 Grupo de Nómina" ReadOnly="true" Variant="Variant.Outlined" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.CostCenterName"
                                              Label="🏢 Centro de Costo" ReadOnly="true" Variant="Variant.Outlined"
                                              Adornment="Adornment.Start" AdornmentText="@_employee.CostCenterCode" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.ContractTypeName" Label="📄 Tipo de Contrato" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.OccupationalRiskName" Label="⚠️ Riesgo Ocupacional" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════════════ *@
        @* PESTAÑA 2: DATOS BANCARIOS Y SALARIALES *@
        @* ═══════════════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Salario y Banco" Icon="@Icons.Material.Filled.AccountBalance">
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">💰 Datos Salariales</MudText>
                        <MudTextField Value="@($"C$ {_employee.BaseSalary:N2}")" Label="Salario Base Mensual"
                                      ReadOnly="true" Variant="Variant.Outlined" Color="Color.Success" Class="mb-3" />
                        <MudTextField Value="@_employee.HealthProviderName" Label="🏥 Proveedor de Salud"
                                      ReadOnly="true" Variant="Variant.Outlined" />
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🏦 Información Bancaria</MudText>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField Value="@_employee.BankName" Label="Banco" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.BankAccountType ?? "N/A")" Label="Tipo de Cuenta" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.BankAccountNumber ?? "N/A")" Label="Número de Cuenta" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Value="@(_employee.BankBeneficiaryName ?? "N/A")" Label="👤 Titular de la Cuenta"
                                              ReadOnly="true" Variant="Variant.Outlined" Color="Color.Info" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════════════ *@
        @* PESTAÑA 3: DOCUMENTOS (CÉDULA) *@
        @* ═══════════════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Documentos" Icon="@Icons.Material.Filled.Folder">
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="1">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🪪 Cédula Frontal</MudText>
                        @if (!string.IsNullOrEmpty(_employee.IdFrontUrl))
                        {
                            <img src="@GetFullImageUrl(_employee.IdFrontUrl)" alt="Cédula Frontal"
                                 style="max-width: 100%; max-height: 300px; border-radius: 8px; border: 1px solid #ccc;" class="mb-3" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(async () => await ClearDocument("IdFrontUrl"))" Class="mb-2">
                                🗑️ Eliminar
                            </MudButton>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Large" Color="Color.Default" Class="mb-3" />
                            <MudText Class="mb-3">No hay imagen cargada</MudText>
                        }
                        <InputFile id="idFrontUpload" style="display: none;"
                                   OnChange="@(e => HandleFileUpload(e, "id-front"))" accept="image/*,.pdf" />
                        <label for="idFrontUpload" class="mud-button-root mud-button-filled mud-button-filled-primary mud-button-filled-size-medium mud-ripple"
                               style="cursor: pointer; padding: 8px 22px; background-color: var(--mud-palette-primary); color: white; border-radius: 4px; display: inline-flex; align-items: center; gap: 8px;">
                            📤 @(string.IsNullOrEmpty(_employee.IdFrontUrl) ? "Subir Cédula Frontal" : "Reemplazar")
                        </label>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="1">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🪪 Cédula Trasera</MudText>
                        @if (!string.IsNullOrEmpty(_employee.IdBackUrl))
                        {
                            <img src="@GetFullImageUrl(_employee.IdBackUrl)" alt="Cédula Trasera"
                                 style="max-width: 100%; max-height: 300px; border-radius: 8px; border: 1px solid #ccc;" class="mb-3" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(async () => await ClearDocument("IdBackUrl"))" Class="mb-2">
                                🗑️ Eliminar
                            </MudButton>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Large" Color="Color.Default" Class="mb-3" />
                            <MudText Class="mb-3">No hay imagen cargada</MudText>
                        }
                        <InputFile id="idBackUpload" style="display: none;"
                                   OnChange="@(e => HandleFileUpload(e, "id-back"))" accept="image/*,.pdf" />
                        <label for="idBackUpload" class="mud-button-root mud-button-filled mud-button-filled-primary mud-button-filled-size-medium mud-ripple"
                               style="cursor: pointer; padding: 8px 22px; background-color: var(--mud-palette-primary); color: white; border-radius: 4px; display: inline-flex; align-items: center; gap: 8px;">
                            📤 @(string.IsNullOrEmpty(_employee.IdBackUrl) ? "Subir Cédula Trasera" : "Reemplazar")
                        </label>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════════════ *@
        @* PESTAÑA 4: DATOS FISCALES Y LEGALES *@
        @* ═══════════════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Fiscal y Legal" Icon="@Icons.Material.Filled.Gavel">
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🏛️ Datos Fiscales</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.NORUC" Label="🏛️ N° RUC" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@_employee.NOINSS" Label="🏥 N° INSS" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">🌍 Trabajador Extranjero</MudText>
                        @if (!string.IsNullOrEmpty(_employee.Nationality))
                        {
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Value="@_employee.Nationality" Label="Nacionalidad" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Value="@(_employee.WorkPermitNumber ?? "N/A")" Label="N° Permiso de Trabajo" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Value="@(_employee.WorkPermitExpirationDate?.ToString("dd/MM/yyyy") ?? "N/A")"
                                                  Label="Vencimiento Permiso" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Normal" Dense="true">
                                <MudText Typo="Typo.body2">Este empleado es nacional (nicaragüense)</MudText>
                            </MudAlert>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">📝 Notas y Observaciones</MudText>
                        <MudTextField Value="@(_employee.Notes ?? "Sin observaciones")"
                                      Label="Notas" ReadOnly="true" Variant="Variant.Outlined" Lines="3" />
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════════════ *@
        @* PESTAÑA 5: CONDICIONES ESPECIALES *@
        @* ═══════════════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Condiciones" Icon="@Icons.Material.Filled.Tune">
            <MudGrid Class="mt-2">
                @* ── Estado y Período de Prueba ── *@
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">⚙️ Estado y Período de Prueba</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@GetStatusText(_employee.EmploymentStatus)"
                                              Label="Estado Laboral" ReadOnly="true" Variant="Variant.Outlined"
                                              Color="@GetStatusColor(_employee.EmploymentStatus)" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool" Value="@_employee.IsTrustEmployee"
                                             Label="Empleado de Confianza (Art. 44)" ReadOnly="true" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool" Value="@_employee.UsesTimeClock"
                                             Label="Usa Reloj de Marcas" ReadOnly="true" Color="Color.Info" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.ProbationStartDate?.ToString("dd/MM/yyyy") ?? "N/A")"
                                              Label="Inicio Período de Prueba" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(_employee.ProbationEndDate?.ToString("dd/MM/yyyy") ?? "N/A")"
                                              Label="Fin Período de Prueba" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            @if (_employee.IsOnProbation)
                            {
                                <MudItem xs="12">
                                    <MudAlert Severity="Severity.Info" Dense="true">
                                        <MudText Typo="Typo.body2">⏳ Este empleado se encuentra actualmente en período de prueba</MudText>
                                    </MudAlert>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                @* ── Grupo de Nómina ── *@
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">💼 Grupo de Nómina</MudText>
                        <MudTextField Value="@(_employee.PayrollGroupName ?? "No asignado")"
                                      Label="Nombre del Grupo" ReadOnly="true" Variant="Variant.Outlined" Color="Color.Primary" Class="mb-3" />
                        <MudAlert Severity="Severity.Info" Dense="true">
                            <MudText Typo="Typo.body2">
                                ℹ️ El grupo de nómina determina en qué colilla se procesará el pago de este empleado.
                                Se puede modificar desde <strong>"Editar Empleado"</strong>.
                            </MudText>
                        </MudAlert>
                    </MudPaper>
                </MudItem>

                @* ── Beneficios en Especie ── *@
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">💼 Beneficios en Especie</MudText>
                        @if (_employee.BenefitsInKindValue.HasValue && _employee.BenefitsInKindValue > 0)
                        {
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Value="@($"C$ {_employee.BenefitsInKindValue:N2}")"
                                                  Label="Valor Mensual" ReadOnly="true" Variant="Variant.Outlined" Color="Color.Success" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Value="@_employee.BenefitsInKindDescription"
                                                  Label="Descripción" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Normal" Dense="true">
                                <MudText Typo="Typo.body2">Este empleado no recibe beneficios en especie</MudText>
                            </MudAlert>
                        }
                    </MudPaper>
                </MudItem>

                @* ── Suspensión (condicional) ── *@
                @if (_employee.EmploymentStatus == "Suspended")
                {
                    <MudItem xs="12">
                        <MudPaper Class="pa-4" Elevation="0">
                            <MudText Typo="Typo.subtitle1" Class="mb-3">⏸️ Información de Suspensión</MudText>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Value="@(_employee.SuspensionStartDate?.ToString("dd/MM/yyyy") ?? "N/A")"
                                                  Label="Inicio Suspensión" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
