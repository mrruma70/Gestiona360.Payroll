    private void ConfirmDelete(BranchDto branch)
    {
        _deleteTarget = branch;
        _deleteDialogOpen = true;
        StateHasChanged(); // Fuerza a Blazor a re-renderizar
    }

    private async Task DeleteAsync()
    {
        if (_deleteTarget == null) return;

        try
        {
            var response = await Http.DeleteAsync($"api/branches/{_deleteTarget.Id}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"✅ Sucursal '{_deleteTarget.Name}' desactivada", Severity.Success);
                await LoadBranchesData();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"⚠️ {error}", Severity.Warning);
            }
            else
            {
                Snackbar.Add($"❌ Error {(int)response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleteDialogOpen = false;
            _deleteTarget = null;
        }
    }

