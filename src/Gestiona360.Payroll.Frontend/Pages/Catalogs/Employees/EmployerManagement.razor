    /// <summary>
    /// Exporta la ficha legal de la empresa a PDF usando el motor de reportes.
    /// </summary>
    private async Task ExportCompanyLegalSheetAsync()
    {
        _isExportingLegalSheet = true;
        StateHasChanged();

        try
        {
            // ✅ Cambiar a PdfFicha
            var response = await Http.GetAsync("api/reports/company-legal-sheet?format=PdfFicha");

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error: {error}", Severity.Error);
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"Ficha_Legal_{_company?.LegalName?.Replace(" ", "_") ?? "Empresa"}_{DateTime.Now:yyyyMMdd}.pdf";

            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "application/pdf", fileName);
            Snackbar.Add("✅ Ficha legal exportada correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExportingLegalSheet = false;
            StateHasChanged();
        }
    }
