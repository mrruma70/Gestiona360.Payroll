    protected override async Task OnInitializedAsync()
    {
        await LoadCompanyData();
        await LoadGlobalConfig();   // carga los años disponibles y los datos por defecto
        await LoadBranchesData();
        await LoadCatalogs();
    }

    private async Task LoadCompanyData()
    {
        _isLoadingCompany = true;
        _company = await Http.GetFromJsonAsync<CompanyDto>("api/companies/main");
        _isLoadingCompany = false;
    }

    private async Task LoadGlobalConfig()
    {
        _isLoadingConfig = true;
        try
        {
            // ✅ Construir URL con los 4 años independientes
            string url = $"api/config/global?yearINSS={_selectedINSSYear}&yearIR={_selectedIRYear}&yearMitrab={_selectedMitrabYear}&yearINATEC={_selectedINATECYear}";
            _globalConfig = await Http.GetFromJsonAsync<GlobalConfigDto>(url);

            if (_globalConfig != null)
            {
                _inssHistory = _globalConfig.INSSHistory;
                _availableINSSYears = _globalConfig.AvailableINSSYears;
                _availableIRYears = _globalConfig.AvailableIRYears;
                _availableMitrabYears = _globalConfig.AvailableMitrabYears;
                _availableINATECYears = _globalConfig.AvailableINATECYears;

                // Si aún no hay año seleccionado, tomar el más reciente de cada lista
                if (_selectedINSSYear == 0 && _availableINSSYears.Any())
                    _selectedINSSYear = _availableINSSYears.First();
                if (_selectedIRYear == 0 && _availableIRYears.Any())
                    _selectedIRYear = _availableIRYears.First();
                if (_selectedMitrabYear == 0 && _availableMitrabYears.Any())
                    _selectedMitrabYear = _availableMitrabYears.First();
                if (_selectedINATECYear == 0 && _availableINATECYears.Any())
                    _selectedINATECYear = _availableINATECYears.First();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando configuración global: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingConfig = false;
            StateHasChanged();
        }
    }

