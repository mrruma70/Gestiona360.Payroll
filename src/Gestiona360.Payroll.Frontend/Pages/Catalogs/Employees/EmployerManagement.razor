@page "/employer-management"
@using System.Net.Http.Json
@using MudBlazor
@using Gestiona360.Payroll.Application.Contracts.DTOs
@using Gestiona360.Payroll.Application.Contracts.Requests
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService dialogService
@inject IJSRuntime JS

<MudText Typo="Typo.h5" Class="mb-4">🏢 Gestión de Empleadores</MudText>

<MudTabs Elevation="1" Rounded="true" Border="true" ApplyEffectsToContainer="true">

    <!-- PESTAÑA 1: EMPRESA PRINCIPAL -->
    <MudTabPanel Text="Empresa Principal" Icon="@Icons.Material.Filled.Business">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">📋 Datos de la Empresa Licenciataria</MudText>
            <MudDivider Class="mb-4" />
            @if (_isLoadingCompany)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_company != null)
            {
                <MudForm @ref="_companyForm">
                    <MudGrid>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.LegalName" Label="🏛️ Nombre Legal *" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.CommercialName" Label="🏷️ Nombre Comercial" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.TaxId" Label="🆔 RUC/NIT *" Variant="Variant.Outlined" Required="true" HelperText="Formato: JXXXXXXXXXXXXX" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.INSSEmployerCode" Label="📋 Cód. Patronal INSS *" Variant="Variant.Outlined" Required="true" HelperText="Formato: P-XXXXXX" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.EconomicActivityCode" Label="📊 Actividad CIIU *" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_company.DefaultCurrency" Label="🌍 Moneda Base *" Variant="Variant.Outlined" Required="true">
                                <MudSelectItem T="string" Value="@("NIO")">NIO (Córdobas)</MudSelectItem>
                                <MudSelectItem T="string" Value="@("USD")">USD (Dólares)</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.LegalRepresentative" Label="👤 Representante Legal *" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.LegalRepresentativeId" Label="Cédula Rep. Legal *" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.City" Label="Ciudad / Departamento *" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6"><MudNumericField @bind-Value="_company.TotalActiveEmployees" Label="Empleados Activos" Variant="Variant.Outlined" ReadOnly="true" /></MudItem>
                        <MudItem xs="12"><MudTextField @bind-Value="_company.Address" Label="📍 Dirección Fiscal *" Variant="Variant.Outlined" Required="true" Lines="2" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.Email" Label="📧 Correo Electrónico *" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_company.Phone" Label="📞 Teléfono *" Variant="Variant.Outlined" Required="true" /></MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField Value="@($"✅ {_globalConfig?.LatestExchangeRate.BCNRate:F2} (12:00)")" Label="💱 Tasa BCN" Variant="Variant.Outlined" ReadOnly="true" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="int" @bind-Value="_company.DefaultPayrollFrequencyId" Label="⚙️ Frecuencia Default *" Variant="Variant.Outlined" Required="true">
                                <MudSelectItem T="int" Value="1">Semanal</MudSelectItem>
                                <MudSelectItem T="int" Value="2">Quincenal</MudSelectItem>
                                <MudSelectItem T="int" Value="3">Mensual</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" Class="d-flex align-center">
                            <MudSwitch @bind-Value="_company.DefaultIsZoneFranca" Label="Zona Franca" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12"><MudTextField @bind-Value="_company.LogoUrl" Label="🖼️ Logo Empresa (URL)" Variant="Variant.Outlined" Placeholder="https://..." /></MudItem>
                    </MudGrid>
                    <div class="d-flex justify-end gap-2 mt-4">
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                   Color="Color.Error"
                                   Disabled="@_isExportingLegalSheet"
                                   OnClick="ExportCompanyLegalSheetAsync">
                            @if (_isExportingLegalSheet)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Generando Ficha...</span>
                            }
                            else
                            {
                                <span>📄 Exportar Ficha Legal (PDF)</span>
                            }
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCompanyAsync">💾 Guardar Cambios</MudButton>
                    </div>
                </MudForm>
            }
            else
            {
                <MudAlert Severity="Severity.Warning">No se encontró configuración de empresa principal.</MudAlert>
            }
        </MudPaper>
    </MudTabPanel>

    <!-- PESTAÑA 2: SUCURSALES -->
    <MudTabPanel Text="Sucursales" Icon="@Icons.Material.Filled.AccountBalance">
        <MudTable T="BranchDto" Items="@_branches" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <MudText Typo="Typo.h6">🏗️ Gestión de Sucursales</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.TableChart"
                           Color="Color.Success"
                           Disabled="@_isExportingBranches"
                           OnClick="ExportBranchesListAsync">
                    @if (_isExportingBranches)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Generando Excel...</span>
                    }
                    else
                    {
                        <span>📤 Exportar Listado (Excel)</span>
                    }
                </MudButton>
                <MudTextField T="string" Placeholder="📍 Buscar..." Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 200px;" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDrawer">➕ Nueva Sucursal</MudButton>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Código</MudTh>
                <MudTh>Nombre</MudTh>
                <MudTh>Ciudad / Dirección</MudTh>
                <MudTh>Centro Costo</MudTh>
                <MudTh>Estado</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Código">@context.Code</MudTd>
                <MudTd DataLabel="Nombre">@context.Name</MudTd>
                <MudTd DataLabel="Ciudad">@context.City, @context.Address</MudTd>
                <MudTd DataLabel="Centro Costo">@context.CostCenterName</MudTd>
                <MudTd DataLabel="Estado">
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive? Color.Success: Color.Warning)">@(context.IsActive ? "🟢 Act" : "🟡 Inac")</MudChip>
                </MudTd>
                <MudTd DataLabel="Acciones">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditDrawer(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDelete(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    @if (_deleteDialogOpen)
    {
        <MudOverlay Visible="true" DarkBackground="true" OnClick="() => _deleteDialogOpen = false">
            <MudPaper Class="pa-6" Style="width:400px; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:2000; background:#1E1E1E; border:1px solid #444; border-radius:12px;">
                <MudText Typo="Typo.h6" Style="color:#FFD54F; font-weight:700;">Confirmar eliminación</MudText>
                <MudText Class="mt-4" Style="color:#F5F5F5;">¿Desactivar la sucursal "@(_deleteTarget?.Name)"?</MudText>
                <div class="d-flex justify-end mt-6 gap-3">
                    <MudButton Variant="Variant.Text" OnClick="() => _deleteDialogOpen = false">Cancelar</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAsync">Desactivar</MudButton>
                </div>
            </MudPaper>
        </MudOverlay>
    }

  
    <!-- PESTAÑA 3: CONFIGURACIÓN GLOBAL -->
    <MudTabPanel Text="Configuración Global" Icon="@Icons.Material.Filled.Settings">
        @if (_isLoadingConfig)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_globalConfig != null)
        {
            <MudTabs Elevation="0" Border="false" PanelClass="pa-2">

                <!-- 🔽 TAB: FISCALES (INSS, IR, INATEC) -->
                <MudTabPanel Text="📊 Fiscales" Icon="@Icons.Material.Filled.Assessment">

                    <!-- SECCIÓN INSS CON HISTORIAL Y ACCIÓN -->
                    <MudPaper Class="pa-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <MudText Typo="Typo.subtitle1">🏛️ Historial de Configuración INSS</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewINSSValidityDialog">
                                ➕ Registrar Nueva Vigencia
                            </MudButton>
                        </div>
                        <MudDivider Class="mb-2" />

                        <!-- Aquí deberías cargar una lista _inssHistory desde el backend (GetINSSHistoryQuery) -->
                        <MudTable T="INSSConfigDto" Items="@_inssHistory" Hover="true" Dense="true">
                            <HeaderContent>
                                <MudTh>Vigencia Desde</MudTh>
                                <MudTh>Vigencia Hasta</MudTh>
                                <MudTh>Fundamento Legal</MudTh>
                                <MudTh>Trabajador %</MudTh>
                                <MudTh>Empleador %</MudTh>
                                <MudTh>Tope Salarial</MudTh>
                                <MudTh>Estado</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.EffectiveFrom.ToString("dd/MM/yyyy")</MudTd>
                                <MudTd>@(context.EffectiveTo?.ToString("dd/MM/yyyy") ?? "Vigente")</MudTd>
                                <MudTd>@context.LegalReference</MudTd>
                                <MudTd>@context.RateWorker.ToString("F2")%</MudTd>
                                <MudTd>@context.RateEmployerLarge.ToString("F2")%</MudTd>
                                <MudTd>C$ @context.MaxSalaryCap.ToString("N2")</MudTd>
                                <MudTd>
                                    @if (context.EffectiveTo == null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Vigente</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">⏳ Histórico</MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>

                    <!-- ✅ SELECTOR DE AÑO PARA IR (INDEPENDIENTE) -->
                    <MudPaper Class="pa-4 mb-4">
                        <MudSelect T="int" Label="Año de la tabla IR" @bind-Value="_selectedIRYear"
                                   Items="_availableIRYears" Variant="Variant.Outlined" Class="mb-3" Style="width: 250px"
                                   OnChange="@((int year) => LoadGlobalConfig())">
                            @foreach (var year in _availableIRYears)
                            {
                                <MudSelectItem T="int" Value="@year">@year</MudSelectItem>
                            }
                        </MudSelect>
                    </MudPaper>

                    <!-- ✅ SECCIÓN IR CON VIGENCIA TEMPORAL -->
                    <MudPaper Class="pa-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <MudText Typo="Typo.subtitle1">🧾 IR - Impuesto sobre la Renta (Vigencia @_selectedIRYear)</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Ley 822 + Reforma 891</MudChip>
                        </div>
                        <MudDivider Class="mb-2" />

                        <MudTable T="IR_TaxBracketDto" Items="@_globalConfig.IRTaxBrackets" Hover="true" Dense="true" Class="mt-3">
                            <HeaderContent>
                                <MudTh>Tramo</MudTh>
                                <MudTh>Base</MudTh>
                                <MudTh>% Marginal</MudTh>
                                <MudTh>Exceso de</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Tramo">
                                    @if (context.ToAmount == null)
                                    {
                                        <span>C$ @context.FromAmount.ToString("N0") o más</span>
                                    }
                                    else
                                    {
                                        <span>C$ @context.FromAmount.ToString("N0") - C$ @context.ToAmount.Value.ToString("N0")</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Base">C$ @context.FixedTax.ToString("N0")</MudTd>
                                <MudTd DataLabel="% Marginal">@context.MarginalRate.ToString("F0")%</MudTd>
                                <MudTd DataLabel="Exceso">
                                    @if (context.FromAmount > 0)
                                    {
                                        <span>C$ @context.FromAmount.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span>C$0</span>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>

                        <div class="d-flex gap-2 mt-3">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Upload"
                                       OnClick="OpenImportDgiDialogAsync">
                                📥 Importar Tabla DGI CSV
                            </MudButton>
                        </div>
                    </MudPaper>

                    <!-- ✅ SECCIÓN INATEC CON HISTORIAL Y ACCIÓN -->
                    <MudPaper Class="pa-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <MudText Typo="Typo.subtitle1">🎓 Historial de Configuración INATEC</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewINATECValidityDialog">
                                ➕ Registrar Nueva Vigencia
                            </MudButton>
                        </div>
                        <MudDivider Class="mb-2" />

                        <!-- Selector de Año -->
                        <MudSelect T="int" Label="Año de la tabla INATEC" @bind-Value="_selectedINATECYear"
                                   Items="_availableINATECYears" Variant="Variant.Outlined" Class="mb-3" Style="width: 250px"
                                   OnChange="@((int year) => LoadGlobalConfig())">
                            @foreach (var year in _availableINATECYears)
                            {
                                <MudSelectItem T="int" Value="@year">@year</MudSelectItem>
                            }
                        </MudSelect>

                        <!-- Configuración Actual -->
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <MudText Typo="Typo.subtitle2">🎓 INATEC - Aporte Formación Técnica (Vigencia @_globalConfig.INATECConfig.Year)</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@_globalConfig.INATECConfig.LegalReference</MudChip>
                        </div>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Tasa Patronal %"
                                              Value="@($"{_globalConfig.INATECConfig.Rate:F2} %")"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              HelperText="Sobre nómina bruta" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Excepciones"
                                              Value="@_globalConfig.INATECConfig.Exceptions"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
               

                </MudTabPanel>

                <!-- 🔽 TAB: LABORALES (MITRAB) -->
                <MudTabPanel Text="🏛️ Laborales" Icon="@Icons.Material.Filled.Work">
                    <MudPaper Class="pa-4">
                        <!-- ✅ SELECTOR DE AÑO PARA MITRAB (INDEPENDIENTE) -->
                        <MudSelect T="int" Label="Año del acuerdo MITRAB" @bind-Value="_selectedMitrabYear"
                                   Items="_availableMitrabYears" Variant="Variant.Outlined" Class="mb-3" Style="width: 250px"
                                   OnChange="@((int year) => LoadGlobalConfig())">
                            @foreach (var year in _availableMitrabYears)
                            {
                                <MudSelectItem T="int" Value="@year">@year</MudSelectItem>
                            }
                        </MudSelect>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <MudText Typo="Typo.subtitle1">💰 Salarios Mínimos MITRAB (Vigencia @_selectedMitrabYear)</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Acuerdo MITRAB @_selectedMitrabYear</MudChip>
                        </div>
                        <MudDivider Class="mb-2" />

                        <MudTable T="MinimumWageDto" Items="@_globalConfig.MinimumWages" Hover="true" Dense="true">
                            <HeaderContent>
                                <MudTh>Sector</MudTh>
                                <MudTh>Salario C$</MudTh>
                                <MudTh>Salario USD</MudTh>
                                <MudTh>Estado</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Sector</MudTd>
                                <MudTd>@context.MonthlyAmountNIO.ToString("N2")</MudTd>
                                <MudTd>@context.MonthlyAmountUSD.ToString("N2")</MudTd>
                                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Vigente</MudChip></MudTd>
                            </RowTemplate>
                        </MudTable>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="OpenImportMitrabDialogAsync">
                            📥 Importar Acuerdo MITRAB (CSV)
                        </MudButton>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="🔐 Seguridad" Icon="@Icons.Material.Filled.Security">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1">🔒 Políticas de Cierre e Inmutabilidad</MudText>
                        <MudDivider Class="mb-2" />
                        <MudGrid>
                            <MudItem xs="12" sm="6"><MudSwitch T="bool" Label="Bloquear UPDATE/DELETE en períodos cerrados" Checked="true" ReadOnly="true" Color="Color.Success" /></MudItem>
                            <MudItem xs="12" sm="6"><MudSwitch T="bool" Label="Requerir Firma Digital Doble" Checked="true" ReadOnly="true" Color="Color.Success" /></MudItem>
                            <MudTextField Label="Algoritmo de Hash" Value="@("SHA-256")" ReadOnly="true" Variant="Variant.Outlined" />
                        </MudGrid>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="🔔 Notificaciones" Icon="@Icons.Material.Filled.Notifications">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1">🏦 Integraciones</MudText>
                        <MudDivider Class="mb-2" />
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="API BCN" Value="@("https://www.bcn.gob.ni/api/tipo-cambio")" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6"><MudTextField Label="Última Sync" Value="@(_globalConfig.LatestExchangeRate.Date.ToString("dd/MM/yyyy HH:mm"))" ReadOnly="true" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.body2">Bancos ACH:</MudText>
                                <MudChip T="string" Color="Color.Primary">BAC</MudChip>
                                <MudChip T="string" Color="Color.Primary">Banpro</MudChip>
                                <MudChip T="string" Color="Color.Primary">Lafise</MudChip>
                                <MudChip T="string" Color="Color.Primary">Ficohsa</MudChip>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudTabPanel>
            </MudTabs>
        }
    </MudTabPanel>
</MudTabs>

<!-- DRAWER PARA SUCURSALES (sin cambios) -->
<MudDrawer @bind-Open="_drawerOpen"
           Anchor="Anchor.Right"
           Variant="DrawerVariant.Temporary"
           Width="480px"
           Elevation="2">
    <div class="drawer-header pa-4">
        <MudText Typo="Typo.h6">@(_isEditing ? "✕ Editar Sucursal" : "✕ Nueva Sucursal")</MudText>
    </div>
    <div class="drawer-content pa-4">
        <MudForm @ref="_branchForm">
            <MudTextField @bind-Value="_branchModel.Code" Label="🏷️ Código Interno (SUC-XXX)" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            <MudTextField @bind-Value="_branchModel.Name" Label="🏢 Nombre" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            <MudTextField @bind-Value="_branchModel.Address" Label="📍 Dirección" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Required="true" />
            <MudTextField @bind-Value="_branchModel.City" Label="🏙️ Ciudad" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            <MudTextField @bind-Value="_branchModel.Phone" Label="📞 Teléfono Suc." Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />

            <MudSelect T="Guid?" @bind-Value="_branchModel.ManagerEmployeeId" Label="👤 Gerente Sucursal" Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var emp in _activeEmployees)
                {
                    <MudSelectItem T="Guid?" Value="@emp.Id">@emp.FullName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="Guid?" @bind-Value="_branchModel.DefaultCostCenterId" Label="💰 Centro de Costo Default" Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var cc in _costCenters)
                {
                    <MudSelectItem T="Guid?" Value="@cc.Id">@cc.Code - @cc.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSwitch @bind-Value="_branchModel.IsZoneFranca" Label="🏭 ¿Opera en Zona Franca?" Color="Color.Primary" Class="mt-2" />
            <MudSwitch @bind-Value="_branchModel.IsActive" Label="📊 Estado Activo" Color="Color.Success" Class="mt-2" />
        </MudForm>
    </div>
    <div class="drawer-footer pa-4 d-flex justify-end gap-2">
        <MudButton Variant="Variant.Text" OnClick="CloseDrawer">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveBranchAsync">💾 Guardar Sucursal</MudButton>
    </div>
</MudDrawer>

@code {
    private CompanyDto? _company;
    private bool _isLoadingCompany = true;
    private MudForm? _companyForm;
    private GlobalConfigDto? _globalConfig;
    private bool _isLoadingConfig = true;
    private List<BranchDto> _branches = new();
    private bool _drawerOpen = false;
    private bool _isEditing = false;
    private MudForm? _branchForm;
    private CreateBranchRequest _branchModel = new();

    private List<EmployeeDto> _activeEmployees = new();
    private List<CostCenterDto> _costCenters = new();

 

    private string _exencionAnual = "C$ 100,000";
    private string _riesgosProfesionales = "R01: 0 % | R02: 0.5 % | R03: 1.0 %";

