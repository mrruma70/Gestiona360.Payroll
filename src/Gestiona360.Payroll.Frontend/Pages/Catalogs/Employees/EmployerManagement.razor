    /// <summary>
    /// Exporta el listado de sucursales a Excel usando el motor de reportes.
    /// </summary>
    private async Task ExportBranchesListAsync()
    {
        _isExportingBranches = true;
        StateHasChanged();

        try
        {
            var response = await Http.GetAsync("api/reports/branches-list?format=Excel");

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error generando listado: {error}", Severity.Error);
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"Sucursales_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", fileName);
            Snackbar.Add("✅ Listado de sucursales exportado correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExportingBranches = false;
            StateHasChanged();
        }
    }

