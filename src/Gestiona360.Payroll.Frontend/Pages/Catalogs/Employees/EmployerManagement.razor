    }

    private void OpenEditDrawer(BranchDto branch)
    {
        _isEditing = true;
        _editingBranchId = branch.Id; // ✅ Guardar el ID
        _branchModel = new CreateBranchRequest
        {
            Code = branch.Code,
            Name = branch.Name,
            Address = branch.Address,
            City = branch.City,
            Phone = branch.Phone,
            ManagerEmployeeId = branch.ManagerEmployeeId,
            DefaultCostCenterId = branch.DefaultCostCenterId,
            IsZoneFranca = branch.IsZoneFranca,
            IsActive = branch.IsActive,
            CompanyId = _company?.Id ?? Guid.Empty
        };
        _drawerOpen = true;
        _branchForm?.ResetValidation();
    }

    private async Task SaveBranchAsync()
    {
        await _branchForm!.Validate();
        if (!_branchForm.IsValid) return;

        try
        {
            HttpResponseMessage response;

            if (_isEditing)
            {
                var update = new UpdateBranchRequest
                {
                    Code = _branchModel.Code.Trim().ToUpper(),
                    Name = _branchModel.Name.Trim(),
                    Address = _branchModel.Address.Trim(),
                    City = _branchModel.City.Trim(),
                    Phone = _branchModel.Phone.Trim(),
                    // ✅ ENVIAR LOS 3 CAMPOS
                    ManagerEmployeeId = _branchModel.ManagerEmployeeId,
                    DefaultCostCenterId = _branchModel.DefaultCostCenterId,
                    IsZoneFranca = _branchModel.IsZoneFranca,
                    IsActive = _branchModel.IsActive
                };

                response = await Http.PutAsJsonAsync($"api/branches/{_editingBranchId}", update);
            }
            else
            {
                // _branchModel ya es CreateBranchRequest, se envía completo
                _branchModel.Code = _branchModel.Code.Trim().ToUpper();
                response = await Http.PostAsJsonAsync("api/branches", _branchModel);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(_isEditing ? "✅ Sucursal actualizada" : "✅ Sucursal creada", Severity.Success);
                CloseDrawer();
                await LoadBranchesData();
                return;
            }

            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"❌ Error {(int)response.StatusCode}: {error}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
    }

