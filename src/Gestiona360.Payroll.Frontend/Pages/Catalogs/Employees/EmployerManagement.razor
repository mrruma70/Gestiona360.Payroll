    private async Task SaveCompanyAsync()
    {
        await _companyForm!.Validate();
        if (!_companyForm.IsValid || _company == null) return;

        try
        {
            var request = new UpdateCompanyRequest
            {
                Id = _company.Id,
                LegalName = _company.LegalName,
                CommercialName = _company.CommercialName,
                TaxId = _company.TaxId,
                INSSEmployerCode = _company.INSSEmployerCode,
                EconomicActivityCode = _company.EconomicActivityCode,
                DefaultCurrency = _company.DefaultCurrency,
                LegalRepresentative = _company.LegalRepresentative,
                LegalRepresentativeId = _company.LegalRepresentativeId,
                Address = _company.Address,
                City = _company.City,
                Department = _company.Department, // ← Cambiar de "department" a "Department"
                TotalActiveEmployees = _company.TotalActiveEmployees,
                Phone = _company.Phone,
                Email = _company.Email,
                DefaultPayrollFrequencyId = _company.DefaultPayrollFrequencyId,
                DefaultIsZoneFranca = _company.DefaultIsZoneFranca,
                LogoUrl = _company.LogoUrl
            
                
            };
            //await Http.PutAsJsonAsync("api/companies/main", request);
             var response = await Http.PutAsJsonAsync("api/companies/main", request);
            if (!response.IsSuccessStatusCode)
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error {response.StatusCode}: {errorContent}", Severity.Error);
                Console.WriteLine(errorContent);
                return;
            }

            Snackbar.Add("✅ Datos de empresa actualizados", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error); }
    }

    private void OpenAddDrawer()
