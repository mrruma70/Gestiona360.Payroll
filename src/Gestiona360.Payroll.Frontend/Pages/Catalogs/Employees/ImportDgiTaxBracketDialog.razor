@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">📥 Importación de Matriz Fiscal - DGI (CSV)</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Square="true" Class="my-2">
                    <strong>Regla de Integridad Fiscal:</strong> La tabla progresiva del IR anual (Ley 822) no permite actualizaciones parciales. Al ejecutar esta carga, se <u>reemplazarán por completo</u> los rangos impositivos del año fiscal correspondiente.
                </MudAlert>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">📄 Archivo de Configuración Fiscal (.csv):</MudText>

                <!-- InputFile oculto - ahora acepta .csv -->
                <InputFile OnChange="@OnFileSelected" accept=".csv" id="dgiFileInput" style="display: none;" />

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Code"
                           OnClick="TriggerFilePicker">
                    @(_file == null ? "Seleccionar CSV Oficial DGI" : _file.Name)
                </MudButton>

                @if (_file != null)
                {
                    <MudText Typo="Typo.caption" Class="mt-2" Style="color: green;">
                        ✓ Archivo estructurado listo (@((_file.Size / 1024.0).ToString("F2")) KB)
                    </MudText>
                }
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   Disabled="@(_file == null || _isProcessing)"
                   OnClick="SubmitAsync">
            @if (_isProcessing)
            {
                <MudProgressCircular Class="ms-n1 me-1" Size="Size.Small" Indeterminate="true" />
                <span>Procesando Matriz...</span>
            }
            else
            {
                <span>🚀 Reemplazar e Importar</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    private bool _isProcessing = false;
    private IBrowserFile? _file;

    private async Task TriggerFilePicker()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('dgiFileInput').click()");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            _file = file;
            Snackbar.Add($"✓ Archivo seleccionado: {file.Name}", Severity.Info);
        }
        else
        {
            _file = null;
            Snackbar.Add("❌ El archivo debe tener extensión .csv", Severity.Error);
        }
        await InvokeAsync(StateHasChanged);
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitAsync()
    {
        if (_file == null) return;

        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var content = new MultipartFormDataContent();
            var fileStream = _file.OpenReadStream(maxAllowedSize: 3 * 1024 * 1024);
            var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("text/csv");
            content.Add(streamContent, "file", _file.Name);

            var response = await Http.PostAsync("api/employees/dgi-tax-brackets/import", content);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Matriz progresiva DGI IR procesada exitosamente.", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error: {errorMsg}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"⚠️ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}