    //     if (!System.Text.RegularExpressions.Regex.IsMatch(value, @"^\d{3}-\d{6}-\d{4}[A-Z0-9]$"))
    //         return "Formato inválido (XXX-XXXXXX-XXXXX)";
    //     return null;
    // }

    private string ValidateEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "El correo es requerido";
        if (!System.Text.RegularExpressions.Regex.IsMatch(value, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            return "Correo inválido";
        return null;
    }

    private void OnSalaryChanged(decimal value)
    {
        _model.BaseSalary = value;
        ValidateMinSalary(value);
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        StateHasChanged();

        try
        {
            if (_hireDate.HasValue)
                _model.HireDate = _hireDate.Value;

            var response = await Http.PostAsJsonAsync("api/employees", _model);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Empleado creado exitosamente", Severity.Success);
                Navigation.NavigateTo("/employees");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Error: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private void Cancel() => Navigation.NavigateTo("/employees");

    private async Task ValidateCedulaAndRehire(string value)
    {
        var validationError = ValidateCedula(value);
        if (validationError != null) return;

        try
        {
            var response = await Http.GetAsync($"api/employees/check-rehire/{value}");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RehireCheckResult>();
                if (result != null && result.IsRehire)
                {
                    _isRehire = true;
                    _previousEmployeeName = result.PreviousEmployeeName;
                    _previousEmployeeCode = result.PreviousEmployeeCode;
                    _previousTerminationDate = result.TerminationDate;
                }
                else
                {
                    _isRehire = false;
                }
            }
        }
        catch
        {
            _isRehire = false;
        }

        StateHasChanged();
    }

    private async Task OnDepartmentChanged(int? departmentId)
    {
        // 1. Asignamos el nuevo valor al modelo
        _model.DepartmentId = departmentId;

        // 2. Limpiamos el municipio actual y vaciamos la lista anterior
        _model.MunicipalityId = null;
        _municipalities.Clear();

        // 3. Si se seleccionó un departamento válido, consultamos la API
        if (departmentId.HasValue)
        {
            try
            {
                // Llama al endpoint definido en tu MunicipalitiesController.cs
                _municipalities = await Http.GetFromJsonAsync<List<MunicipalityDto>>($"api/municipalities/by-department/{departmentId.Value}") ?? new();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"❌ Error cargando municipios: {ex.Message}", Severity.Error);
            }
        }

        // 4. Forzamos la recarga de la UI para que el selector de municipios se habilite y muestre datos
        StateHasChanged();
    }

