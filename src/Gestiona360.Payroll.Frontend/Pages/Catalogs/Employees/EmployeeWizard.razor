@page "/employees/new"
@using Gestiona360.Payroll.Application.Contracts.DTOs
@using Gestiona360.Payroll.Application.Contracts.Requests
@using Gestiona360.Payroll.Application.Contracts.DTOs.Employees
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Nuevo Empleado | Gestiona360</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">🆕 Nuevo Registro de Empleado</MudText>

<!-- STEPPER VISUAL - 4 PASOS -->
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudStepper Vertical="false" Linear="true">
        <MudStep Title="Identificación" Icon="@Icons.Material.Filled.Badge"
                 Style="@(_currentStep == 0 ? "color: var(--mud-palette-primary)" : "")">
        </MudStep>
        <MudStep Title="Contacto" Icon="@Icons.Material.Filled.ContactPhone"
                 Style="@(_currentStep == 1 ? "color: var(--mud-palette-primary)" : "")">
        </MudStep>
        <MudStep Title="Contrato" Icon="@Icons.Material.Filled.Work"
                 Style="@(_currentStep == 2 ? "color: var(--mud-palette-primary)" : "")">
        </MudStep>
        <MudStep Title="Banco y Resumen" Icon="@Icons.Material.Filled.AccountBalance"
                 Style="@(_currentStep == 3 ? "color: var(--mud-palette-primary)" : "")">
        </MudStep>
    </MudStepper>
</MudPaper>

<!-- CONTENIDO DEL PASO ACTUAL -->
<MudPaper Class="pa-4" Elevation="1">

    @* ═══════════════════════════════════════════════════════════════ *@
    @* PASO 1: IDENTIFICACIÓN Y DATOS PERSONALES                      *@
    @* ═══════════════════════════════════════════════════════════════ *@
    @if (_currentStep == 0)
    {
        <MudForm @ref="_step1Form">
            <MudText Typo="Typo.h6" Class="mb-3">🪪 Paso 1: Identificación y Datos Personales</MudText>
            <MudDivider Class="mb-4" />

            @* ── Alerta de Reingreso (si aplica) ── *@
            @if (_isRehire)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    <MudText Typo="Typo.body2">
                        <strong>🔄 Reingreso detectado:</strong> Este empleado ya estuvo registrado anteriormente.
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mt-1">
                        👤 Empleado anterior: <strong>@_previousEmployeeName</strong> (@_previousEmployeeCode)<br />
                        📅 Fecha de terminación: @_previousTerminationDate?.ToString("dd/MM/yyyy")<br />
                        🔗 Se vinculará automáticamente como reingreso (PreviousEmployeeId)
                    </MudText>
                </MudAlert>
            }

            @* ── Sección A: Identificación Legal ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">📋 Identificación Legal</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Identification"
                                  Label="🆔 Cédula *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Validation="@(new Func<string, string?>(ValidateCedula))"
                                  Immediate="true"
                                  OnBlur="@(() => ValidateCedulaAndRehire(_model.Identification))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.NOINSS" Label="🏥 Número INSS *"
                                  Variant="Variant.Outlined" Required="true"
                                  HelperText="Obligatorio - Ley 539"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.NORUC" Label="📝 Número RUC"
                                  Variant="Variant.Outlined"
                                  HelperText="Opcional - Solo si aplica"
                                  Immediate="true" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Sección B: Nombre Completo ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">👤 Nombre Completo</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.FirstName" Label="Primer Nombre *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.SecondName" Label="Segundo Nombre"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.LastName" Label="Primer Apellido *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.SecondLastName" Label="Segundo Apellido"
                                  Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Sección C: Datos Demográficos ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">📊 Datos Demográficos</MudText>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_model.BirthDate" Label="🎂 Fecha de Nacimiento"
                                   Variant="Variant.Outlined" MaxDate="DateTime.Today.AddYears(-15)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" @bind-Value="_model.Gender" Label="⚧ Sexo"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("M")">Masculino</MudSelectItem>
                        <MudSelectItem Value="@("F")">Femenino</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" @bind-Value="_model.MaritalStatus" Label="💍 Estado Civil"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("S")">Soltero/a</MudSelectItem>
                        <MudSelectItem Value="@("C")">Casado/a</MudSelectItem>
                        <MudSelectItem Value="@("U")">Unión libre</MudSelectItem>
                        <MudSelectItem Value="@("D")">Divorciado/a</MudSelectItem>
                        <MudSelectItem Value="@("V")">Viudo/a</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    }

    @* ═══════════════════════════════════════════════════════════════ *@
    @* PASO 2: CONTACTO Y DOMICILIO                                   *@
    @* ═══════════════════════════════════════════════════════════════ *@
    @if (_currentStep == 1)
    {
        <MudForm @ref="_step2Form">
            <MudText Typo="Typo.h6" Class="mb-3">📞 Paso 2: Contacto y Domicilio</MudText>
            <MudDivider Class="mb-4" />

            @* ── Sección A: Datos de Contacto ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">📧 Datos de Contacto</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Email" Label="📧 Correo Electrónico *"
                                  Variant="Variant.Outlined" Required="true"
                                  Validation="@(new Func<string, string?>(ValidateEmail))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Phone" Label="☎️ Teléfono"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.MobilePhone" Label="📱 Celular *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Sección B: Domicilio ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">🏠 Domicilio</MudText>
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Address" Label="📍 Dirección"
                                  Variant="Variant.Outlined" Lines="2"
                                  HelperText="Dirección completa del domicilio" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Value="_model.DepartmentId"
                               ValueChanged="OnDepartmentChanged"
                               Label="🗺️ Departamento"
                               Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="int?" Value="null">-- Seleccione --</MudSelectItem>
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem T="int?" Value="@d.Id">@d.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Value="_model.MunicipalityId"
                               ValueChanged="@((int? v) => { _model.MunicipalityId = v; StateHasChanged(); })"
                               Label="🏘️ Municipio"
                               Variant="Variant.Outlined" Clearable="true"
                               Disabled="@(!_model.DepartmentId.HasValue)">
                        <MudSelectItem T="int?" Value="null">-- Seleccione --</MudSelectItem>
                        @foreach (var m in _municipalities)
                        {
                            <MudSelectItem T="int?" Value="@m.Id">@m.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Sección C: Contacto de Emergencia ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">🚨 Contacto de Emergencia</MudText>
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                <MudText Typo="Typo.body2">
                    ℹ️ Es obligatorio registrar al menos un contacto de emergencia por ley.
                </MudText>
            </MudAlert>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.EmergencyContactName" Label="👤 Nombre Completo *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.EmergencyContactPhone" Label="📞 Teléfono *"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.EmergencyContactRelationship" Label="👨‍👩‍👧 Parentesco *"
                                  Variant="Variant.Outlined" Required="true"
                                  HelperText="Ej: Esposa, Padre, Hermano" />
                </MudItem>
            </MudGrid>
        </MudForm>
    }

    @* ═══════════════════════════════════════════════════════════════ *@
    @* PASO 3: DATOS LABORALES Y CONTRATO                             *@
    @* ═══════════════════════════════════════════════════════════════ *@
    @if (_currentStep == 2)
    {
        <MudForm @ref="_step3Form">
            <MudText Typo="Typo.h6" Class="mb-3">💼 Paso 3: Datos Laborales y Contrato</MudText>
            <MudDivider Class="mb-4" />

            @* ── Sección A: Asignación Organizacional ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">🏢 Asignación Organizacional</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_company?.LegalName" Label="🏢 Empresa"
                                  Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" @bind-Value="_model.BranchId" Label="🏙️ Sucursal *"
                               Variant="Variant.Outlined" Required="true">
                        @foreach (var branch in _branches)
                        {
                            <MudSelectItem T="Guid" Value="@branch.Id">@branch.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_model.CostCenterId"
                               Label="🏢 Centro de Costo"
                               Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="Guid?" Value="null">Sin asignar</MudSelectItem>
                        @foreach (var cc in _costCenters)
                        {
                            <MudSelectItem T="Guid?" Value="@cc.Id">@cc.Code - @cc.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" @bind-Value="_model.PayrollGroupId"
                               Label="💼 Grupo de Nómina *"
                               Variant="Variant.Outlined" Required="true"
                               RequiredError="Debe seleccionar un grupo de nómina">
                        @foreach (var pg in _payrollGroups)
                        {
                            <MudSelectItem T="Guid" Value="@pg.Id">@pg.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Sección B: Contrato y Puesto ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">📄 Contrato y Puesto</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_hireDate" Label="📅 Fecha de Ingreso *"
                                   Variant="Variant.Outlined" Required="true"
                                   MinDate="DateTime.Today" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int" Value="_model.ContractTypeId"
                               ValueChanged="@(v => OnContractTypeChanged(v))"
                               Label="📄 Tipo Contrato *"
                               Variant="Variant.Outlined" Required="true">
                        @foreach (var ct in _contractTypes)
                        {
                            <MudSelectItem T="int" Value="@ct.Id">@ct.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" Value="_model.JobGradeId"
                               ValueChanged="@(v => OnJobGradeChanged(v))"
                               Label="👔 Puesto / Nivel *"
                               Variant="Variant.Outlined" Required="true">
                        @foreach (var grade in _jobGrades)
                        {
                            <MudSelectItem T="Guid" Value="@grade.Id">
                                @grade.JobPositionName - @grade.Name
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     Value="_model.BaseSalary"
                                     ValueChanged="@((decimal v) => OnSalaryChanged(v))"
                                     Label="💰 Salario Base (C$) *"
                                     Variant="Variant.Outlined" Required="true"
                                     Min="0m" Step="100m" Format="N2" />
                </MudItem>
                @if (_showMinSalaryWarning)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Error" Dense="true">
                            ⛔ El salario debe ser ≥ C$ @_minSalaryRequired.ToString("N2") (mínimo legal del sector)
                        </MudAlert>
                    </MudItem>
                }
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_model.HealthProviderId"
                               Label="🏥 Proveedor de Salud" Variant="Variant.Outlined">
                        <MudSelectItem T="Guid?" Value="null">Sin proveedor</MudSelectItem>
                        @foreach (var hp in _healthProviders)
                        {
                            <MudSelectItem T="Guid?" Value="@hp.Id">@hp.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Sección C: Reglas Automáticas del Contrato ── *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">⚙️ Reglas Automáticas (Según Tipo de Contrato)</MudText>
            <MudPaper Elevation="1" Class="pa-3">
                <MudGrid>
                    <MudItem xs="6" sm="4">
                        <MudCheckBox T="bool" Value="@(_selectedContractType?.ApplyINSS ?? false)"
                                     Label="INSS" ReadOnly="true" Color="Color.Success" />
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudCheckBox T="bool" Value="@(_selectedContractType?.ApplyIR ?? false)"
                                     Label="IR" ReadOnly="true" Color="Color.Success" />
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudCheckBox T="bool" Value="@(_selectedContractType?.ApplyINATEC ?? false)"
                                     Label="INATEC" ReadOnly="true" Color="Color.Success" />
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudCheckBox T="bool" Value="@((_selectedContractType?.ApplyVacationsDays ?? 0) > 0)"
                                     Label="Vacaciones" ReadOnly="true" Color="Color.Success" />
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudCheckBox T="bool" Value="@(_selectedContractType?.ApplyThirteenthMonth ?? false)"
                                     Label="Aguinaldo" ReadOnly="true" Color="Color.Success" />
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudCheckBox T="bool" Value="@(_selectedContractType?.ApplyIndemnity ?? false)"
                                     Label="Indemnización" ReadOnly="true" Color="Color.Success" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudForm>
    }

    @* ═══════════════════════════════════════════════════════════════ *@
    @* PASO 4: DATOS BANCARIOS Y RESUMEN                              *@
    @* ═══════════════════════════════════════════════════════════════ *@
    @if (_currentStep == 3)
    {
        <MudText Typo="Typo.h6" Class="mb-3">💳 Paso 4: Datos Bancarios y Resumen</MudText>
        <MudDivider Class="mb-4" />

        @* ── Sección A: Datos Bancarios ── *@
        <MudText Typo="Typo.subtitle2" Class="mb-2">🏦 Información Bancaria</MudText>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudSelect T="int?" @bind-Value="_model.BankId" Label="🏦 Banco" Variant="Variant.Outlined">
                    <MudSelectItem T="int?" Value="null">Sin cuenta</MudSelectItem>
                    @foreach (var bank in _banks)
                    {
                        <MudSelectItem T="int?" Value="@bank.Id">@bank.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="string" @bind-Value="_model.BankAccountType" Label="💳 Tipo Cuenta" Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("")">N/A</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Ahorro")">Ahorro</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Corriente")">Corriente</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_model.BankAccountNumber" Label="🔢 Número Cuenta"
                              Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-4">
            💡 <strong>Nota:</strong> Las deducciones especiales (préstamos, embargos) se configuran
            después de la contratación mediante <strong>Acciones de Personal</strong>.
        </MudAlert>

        <MudDivider Class="my-4" />

        @* ── Sección B: Resumen Final ── *@
        <MudText Typo="Typo.subtitle2" Class="mb-2">📋 Resumen de Contratación</MudText>
        <MudPaper Elevation="2" Class="pa-4" Style="background-color: #f8fafc;">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-2"><strong>👤 Datos del Empleado</strong></MudText>
                    <MudText Typo="Typo.body2">
                        <strong>Nombre:</strong> @_model.FirstName @(_model.SecondName) @_model.LastName @(_model.SecondLastName)<br />
                        <strong>Cédula:</strong> @_model.Identification<br />
                        <strong>INSS:</strong> @_model.NOINSS<br />
                        @if (!string.IsNullOrEmpty(_model.NORUC))
                        {
                            <text><strong>RUC:</strong> @_model.NORUC<br /></text>
                        }
                    </MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-2"><strong>💼 Datos Laborales</strong></MudText>
                    <MudText Typo="Typo.body2">
                        <strong>Puesto:</strong> @(_selectedJobGrade?.Name ?? "N/A")<br />
                        <strong>Salario:</strong> C$ @_model.BaseSalary.ToString("N2")<br />
                        <strong>Sucursal:</strong> @(_selectedBranch?.Name ?? "N/A")<br />
                        <strong>Ingreso:</strong> @_hireDate?.ToString("dd/MM/yyyy")<br />
                        <strong>Grupo Nómina:</strong> @(_payrollGroups.FirstOrDefault(p => p.Id == _model.PayrollGroupId)?.Name ?? "N/A")
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudAlert Severity="Severity.Warning" Class="mt-4" Outlined="true">
            <MudText Typo="Typo.body2">
                <strong>⚠️ Importante:</strong> Al crear el empleado, se generará automáticamente su período de prueba
                según el tipo de contrato seleccionado. Los cambios posteriores se gestionarán mediante
                <strong>Acciones de Personal</strong>.
            </MudText>
        </MudAlert>
    }

</MudPaper>

<!-- BOTONES DE NAVEGACIÓN -->
<div class="d-flex justify-space-between mt-4">
    <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancelar</MudButton>

    <div class="d-flex gap-2">
        @if (_currentStep > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="PreviousStep">
                Anterior
            </MudButton>
        }

        @if (_currentStep < 3)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="NextStep" Disabled="@_isValidating">
                Siguiente
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Success"
                       EndIcon="@Icons.Material.Filled.Save"
                       OnClick="SubmitAsync" Disabled="@_isSubmitting">
                @if (_isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Creando...</span>
                }
                else
                {
                    <span>🚀 Crear Empleado</span>
                }
            </MudButton>
        }
    </div>
</div>

@code {
    private int _currentStep = 0;
    private bool _isSubmitting = false;
    private bool _isValidating = false;
    private bool _showMinSalaryWarning = false;
    private decimal _minSalaryRequired = 0;

    private MudForm? _step1Form;
    private MudForm? _step2Form;
    private MudForm? _step3Form;

    private DateTime? _hireDate = DateTime.Today;

    private CreateEmployeeRequest _model = new();
    private CompanyDto? _company;
    private List<BranchDto> _branches = new();
    private List<ContractTypeDto> _contractTypes = new();
    private List<JobGradeDto> _jobGrades = new();
    private List<HealthProviderDto> _healthProviders = new();
    private List<BankDto> _banks = new();
    private List<CostCenterDto> _costCenters = new();
    private List<PayrollGroupDto> _payrollGroups = new();
    private List<DepartmentDto> _departments = new();
    private List<MunicipalityDto> _municipalities = new();

    private ContractTypeDto? _selectedContractType;
    private JobGradeDto? _selectedJobGrade;
    private BranchDto? _selectedBranch;

    private bool _isRehire = false;
    private string? _previousEmployeeName;
    private string? _previousEmployeeCode;
    private DateTime? _previousTerminationDate;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _company = await Http.GetFromJsonAsync<CompanyDto>("api/companies/main");
            _model.CompanyId = _company?.Id ?? Guid.Empty;

            _branches = await Http.GetFromJsonAsync<List<BranchDto>>("api/branches/active") ?? new();
            _contractTypes = await Http.GetFromJsonAsync<List<ContractTypeDto>>("api/contracttypes/all") ?? new();
            _jobGrades = await Http.GetFromJsonAsync<List<JobGradeDto>>("api/jobgrades/active") ?? new();
            _healthProviders = await Http.GetFromJsonAsync<List<HealthProviderDto>>("api/healthproviders/active") ?? new();
            _banks = await Http.GetFromJsonAsync<List<BankDto>>("api/banks/active") ?? new();
            _costCenters = await Http.GetFromJsonAsync<List<CostCenterDto>>("api/costcenters/active") ?? new();
            _payrollGroups = await Http.GetFromJsonAsync<List<PayrollGroupDto>>("api/payrollgroups/active") ?? new();
            _departments = await Http.GetFromJsonAsync<List<DepartmentDto>>("api/departments/active") ?? new();

            if (_payrollGroups.Any())
                _model.PayrollGroupId = _payrollGroups.First().Id;

            if (_contractTypes.Any())
            {
                _model.ContractTypeId = _contractTypes.First().Id;
                _selectedContractType = _contractTypes.First();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error cargando datos: {ex.Message}", Severity.Error);
        }
    }

    private async Task NextStep()
    {
        _isValidating = true;
        StateHasChanged();

        bool isValid = false;

        if (_currentStep == 0)
        {
            if (_step1Form != null)
            {
                await _step1Form.Validate();
                isValid = _step1Form.IsValid;
            }
        }
        else if (_currentStep == 1)
        {
            if (_step2Form != null)
            {
                await _step2Form.Validate();
                isValid = _step2Form.IsValid;
            }
        }
        else if (_currentStep == 2)
        {
            if (_step3Form != null)
            {
                await _step3Form.Validate();
                isValid = _step3Form.IsValid && !_showMinSalaryWarning && _hireDate.HasValue;

                if (_hireDate.HasValue)
                    _model.HireDate = _hireDate.Value;

                if (_showMinSalaryWarning)
                    Snackbar.Add("⚠️ El salario debe ser mayor o igual al mínimo legal", Severity.Warning);
            }
        }

        if (isValid)
        {
            _currentStep++;
            if (_currentStep == 3)
                _selectedBranch = _branches.FirstOrDefault(b => b.Id == _model.BranchId);
        }
        else
        {
            Snackbar.Add("⚠️ Complete todos los campos requeridos correctamente", Severity.Warning);
        }

        _isValidating = false;
        StateHasChanged();
    }

    private void PreviousStep()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
            StateHasChanged();
        }
    }

    private void OnContractTypeChanged(int contractTypeId)
    {
        _selectedContractType = _contractTypes.FirstOrDefault(ct => ct.Id == contractTypeId);
        _model.ContractTypeId = contractTypeId;
        StateHasChanged();
    }

    private void OnJobGradeChanged(Guid jobGradeId)
    {
        _selectedJobGrade = _jobGrades.FirstOrDefault(jg => jg.Id == jobGradeId);
        _model.JobGradeId = jobGradeId;

        if (_selectedJobGrade != null)
        {
            _minSalaryRequired = _selectedJobGrade.MinWageNIO;
            ValidateMinSalary(_model.BaseSalary);
        }
        StateHasChanged();
    }

    private void ValidateMinSalary(decimal salary)
    {
        _showMinSalaryWarning = salary < _minSalaryRequired && _minSalaryRequired > 0;
    }


    private string ValidateCedula(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "La cédula es obligatoria.";

        // Validación matemática estricta
        if (!Gestiona360.Payroll.Application.Contracts.Common.Validators.CedulaValidator.EsValida(value))
            return "La cédula no es válida. Verifique el formato y el dígito verificador (letra final).";

        return null; // Es válida
    }

