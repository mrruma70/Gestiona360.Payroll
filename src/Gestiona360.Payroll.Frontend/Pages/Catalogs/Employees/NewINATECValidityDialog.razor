@using System.Net.Http.Json
@using Gestiona360.Payroll.Domain.Shared.Frontend
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">➕ Registrar Nueva Vigencia INATEC</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Al guardar, el sistema cerrará automáticamente la configuración anterior un día antes de la fecha de inicio que seleccione.
        </MudAlert>

        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_effectiveFrom"
                                   Label="📅 Fecha de Inicio *" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_legalRef"
                                  Label="⚖️ Fundamento Legal (Ej: Ley 1063)" Required="true" />
                </MudItem>

                <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" @bind-Value="_rate"
                                     Label="🎓 Tasa INATEC %"
                                     Min="0m" Max="100m" Step="0.01m" Format="F2" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_exceptions"
                                  Label="🏛️ Excepciones"
                                  Placeholder="MINED, MINSA" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Submit" Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            💾 Guardar Nueva Vigencia
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudBlazor.IMudDialogInstance MudDialog { get; set; }
    private MudForm _form;
    private bool _isSubmitting = false;

    private DateTime? _effectiveFrom = DateTime.Today;
    private string _legalRef = "Ley 1063";
    private decimal _rate = 2.00m;
    private string _exceptions = "MINED, MINSA";

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid || !_effectiveFrom.HasValue) return;

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var request = new CreateNewINATECValidityRequest
            {
                EffectiveFrom = DateOnly.FromDateTime(_effectiveFrom.Value),
                LegalReference = _legalRef,
                Rate = _rate,
                Exceptions = _exceptions
            };

            var response = await Http.PostAsJsonAsync("api/inatecconfigs/new-validity", request);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Nueva vigencia de INATEC registrada correctamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                Snackbar.Add($"❌ Error: {error?.GetValueOrDefault("error") ?? "Error desconocido"}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error de conexión: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }
}