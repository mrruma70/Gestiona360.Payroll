@page "/employees"
@using Gestiona360.Payroll.Application.Contracts.DTOs.Employees
@using Gestiona360.Payroll.Application.Contracts.DTOs
@using Gestiona360.Payroll.Domain.Shared.Frontend
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IDialogService DialogService

<PageTitle>Empleados | Gestiona360</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">👥 Gestión de Empleados</MudText>

<!-- 📊 TARJETAS DE ESTADÍSTICAS MEJORADAS -->
<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" Size="Size.Large" Class="mr-3" />
            <div>
                <MudText Typo="Typo.caption">Total Empleados</MudText>
                <MudText Typo="Typo.h5">@_stats.Total</MudText>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mr-3" />
            <div>
                <MudText Typo="Typo.caption">✅ Activos</MudText>
                <MudText Typo="Typo.h5">@_stats.Active</MudText>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.PauseCircle" Color="Color.Warning" Size="Size.Large" Class="mr-3" />
            <div>
                <MudText Typo="Typo.caption">⏸️ Suspendidos</MudText>
                <MudText Typo="Typo.h5">@_stats.Suspended</MudText>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Info" Size="Size.Large" Class="mr-3" />
            <div>
                <MudText Typo="Typo.caption">⏳ En Prueba</MudText>
                <MudText Typo="Typo.h5">@_stats.OnProbation</MudText>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- 🔍 BARRA DE BÚSQUEDA Y FILTROS MEJORADOS -->
<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <!-- Búsqueda rápida -->
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_searchTerm"
                          Placeholder="🔍 Buscar por nombre, cédula, código, correo, RUC o INSS..."
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyDown="@(async (k) => { if (k.Key == "Enter") await ApplyFilters(); })"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="6" Class="d-flex align-center justify-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Search" OnClick="ApplyFilters">
                Buscar
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFilters">
                Limpiar
            </MudButton>
        </MudItem>

        <!-- Filtros avanzados - Fila 1 -->
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="Guid?" @bind-Value="_filterBranchId" Label="🏙️ Sucursal"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="Guid?" Value="null">Todas</MudSelectItem>
                @foreach (var b in _branches)
                {
                    <MudSelectItem T="Guid?" Value="@b.Id">@b.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="int?" @bind-Value="_filterContractTypeId" Label="📄 Tipo Contrato"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="int?" Value="null">Todos</MudSelectItem>
                @foreach (var ct in _contractTypes)
                {
                    <MudSelectItem T="int?" Value="@ct.Id">@ct.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="int?" @bind-Value="_filterEmploymentStatus" Label="⚙️ Estado Laboral"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="int?" Value="null">Todos</MudSelectItem>
                <MudSelectItem T="int?" Value="0">✅ Activo</MudSelectItem>
                <MudSelectItem T="int?" Value="1">⏸️ Suspendido</MudSelectItem>
                <MudSelectItem T="int?" Value="2">⏹️ Terminado</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="Guid?" @bind-Value="_filterJobPositionId" Label="👔 Puesto"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="Guid?" Value="null">Todos</MudSelectItem>
                @foreach (var jp in _jobPositions)
                {
                    <MudSelectItem T="Guid?" Value="@jp.Id">@jp.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <!-- Filtros avanzados - Fila 2 (NUEVOS) -->
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="bool?" @bind-Value="_filterIsTrustEmployee" Label="👔 Confianza"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="bool?" Value="null">Todos</MudSelectItem>
                <MudSelectItem T="bool?" Value="true">✅ Sí</MudSelectItem>
                <MudSelectItem T="bool?" Value="false">❌ No</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="bool?" @bind-Value="_filterIsForeign" Label="🌍 Extranjero"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="bool?" Value="null">Todos</MudSelectItem>
                <MudSelectItem T="bool?" Value="true">✅ Sí</MudSelectItem>
                <MudSelectItem T="bool?" Value="false">❌ No</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="bool?" @bind-Value="_filterOnProbation" Label="⏳ En Período Prueba"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="bool?" Value="null">Todos</MudSelectItem>
                <MudSelectItem T="bool?" Value="true">✅ Sí</MudSelectItem>
                <MudSelectItem T="bool?" Value="false">❌ No</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="bool?" @bind-Value="_filterIsRehire" Label="🔄 Reingreso"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="bool?" Value="null">Todos</MudSelectItem>
                <MudSelectItem T="bool?" Value="true">✅ Sí</MudSelectItem>
                <MudSelectItem T="bool?" Value="false">❌ No</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- BOTONES DE ACCIÓN -->
<div class="d-flex justify-space-between mb-3">
    <MudButton Variant="Variant.Filled" Color="Color.Success"
               StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenNewEmployeeWizard"
               Size="Size.Large">
        ➕ Nuevo Empleado
    </MudButton>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.FileDownload" OnClick="ExportToExcel"
                   Disabled="@_isExporting">
            @if (_isExporting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Exportando...</span>
            }
            else
            {
                <span>📤 Exportar Excel</span>
            }
        </MudButton>
    </div>
</div>

<!-- 📋 TABLA DE EMPLEADOS MEJORADA -->
<MudTable Items="@_employees" Hover="true" Dense="true" Striped="true"
          Loading="@_isLoading" LoadingProgressColor="Color.Primary"
          RowsPerPage="10">
    <HeaderContent>
        <MudTh Style="width: 80px;">Código</MudTh>
        <MudTh>Empleado</MudTh>
        <MudTh>Puesto / Nivel</MudTh>
        <MudTh>Sucursal</MudTh>
        <MudTh>Centro de Costo</MudTh>
        <MudTh>Fecha Ingreso</MudTh>
        <MudTh Style="width: 120px;">Estado</MudTh>
        <MudTh Style="width: 80px;">Indicadores</MudTh>
        <MudTh Style="width: 60px;">Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Código">
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Empleado">
            <div class="d-flex align-center">
                <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                    @GetInitials(context.FirstName, context.LastName)
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.body2"><strong>@context.FullName</strong></MudText>
                    <MudText Typo="Typo.caption" Style="font-family: monospace;">🆔 @context.Identification</MudText>
                    <MudText Typo="Typo.caption">@context.Email</MudText>
                </div>
            </div>
        </MudTd>
        <MudTd DataLabel="Puesto">
            <MudText Typo="Typo.body2">@context.JobPositionName</MudText>
            <MudText Typo="Typo.caption">@context.JobGradeName</MudText>
        </MudTd>
        <MudTd DataLabel="Sucursal">
            <MudText Typo="Typo.body2">@context.BranchName</MudText>
            <MudText Typo="Typo.caption">@context.BranchCode</MudText>
        </MudTd>
        <MudTd DataLabel="Centro de Costo">
            <MudText Typo="Typo.body2">@context.CostCenterName</MudText>
            <MudText Typo="Typo.caption">@context.CostCenterCode</MudText>
        </MudTd>
        <MudTd DataLabel="Fecha Ingreso">
            <MudText Typo="Typo.body2">@context.HireDate.ToString("dd/MM/yyyy")</MudText>
            <MudText Typo="Typo.caption">@GetAntiguedad(context.HireDate)</MudText>
        </MudTd>
        <MudTd DataLabel="Estado">
            @GetEmploymentStatusChip(context.EmploymentStatus)
        </MudTd>
        <MudTd DataLabel="Indicadores">
            <div class="d-flex gap-1 flex-wrap">
                @if (context.IsOnProbation)
                {
                    <MudTooltip Text="En período de prueba">
                        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Color="Color.Warning" Size="Size.Small" />
                    </MudTooltip>
                }
                @if (context.IsTrustEmployee)
                {
                    <MudTooltip Text="Empleado de confianza">
                        <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Size="Size.Small" />
                    </MudTooltip>
                }
                @if (!string.IsNullOrEmpty(context.Nationality))
                {
                    <MudTooltip Text=@($"Extranjero: {context.Nationality}")>
                        <MudIcon Icon="@Icons.Material.Filled.Public" Color="Color.Info" Size="Size.Small" />
                    </MudTooltip>
                }
                @if (context.PreviousEmployeeId.HasValue)
                {
                    <MudTooltip Text="Reingreso">
                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Color="Color.Success" Size="Size.Small" />
                    </MudTooltip>
                }
            </div>
        </MudTd>
        <MudTd DataLabel="Acciones">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" IconColor="Color.Default" Size="Size.Small" Dense="true">
                <MudMenuItem OnClick="@(() => ViewEmployee(context.Id))" Icon="@Icons.Material.Filled.Visibility">
                    Ver Ficha
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => EditEmployee(context.Id))" Icon="@Icons.Material.Filled.Edit">
                    Editar
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem OnClick="@(() => ViewPersonalActions(context.Id))" Icon="@Icons.Material.Filled.History">
                    Acciones de Personal
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ViewPayrollHistory(context.Id))" Icon="@Icons.Material.Filled.Receipt">
                    Historial Nómina
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ViewConcepts(context.Id))" Icon="@Icons.Material.Filled.Tune">
                    Conceptos
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ViewShifts(context.Id))" Icon="@Icons.Material.Filled.Schedule">
                    Turnos
                </MudMenuItem>
                <MudDivider />
            @*     <MudMenuItem OnClick="@(() => ToggleActive(context))"
                             Icon="@(context.IsActive ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                             Style="@(context.IsActive ? "color: orange" : "color: green")">
                    @(context.IsActive ? "⏸️ Desactivar" : "▶️ Activar")
                </MudMenuItem> *@
            </MudMenu>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
    </PagerContent>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-8">
            🔍 No se encontraron empleados con los filtros seleccionados.
        </MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private bool _isLoading = false;
    private bool _isExporting = false;

    // Filtros existentes
    private string _searchTerm = "";
    private Guid? _filterBranchId;
    private int? _filterContractTypeId;
    private string _filterStatus = "";
    private Guid? _filterJobPositionId;

    // NUEVOS filtros
    private int? _filterEmploymentStatus;
    private bool? _filterIsTrustEmployee;
    private bool? _filterIsForeign;
    private bool? _filterOnProbation;
    private bool? _filterIsRehire;

    // Datos
    private List<EmployeeListDto> _employees = new();
    private EmployeeStatsDto _stats = new();

    // Catálogos para filtros
    private List<BranchDto> _branches = new();
    private List<ContractTypeDto> _contractTypes = new();
    private List<JobPositionDto> _jobPositions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogs();
        await ApplyFilters();
    }

    private async Task LoadCatalogs()
    {
        try
        {
            _branches = await Http.GetFromJsonAsync<List<BranchDto>>("api/branches/active") ?? new();
            _contractTypes = await Http.GetFromJsonAsync<List<ContractTypeDto>>("api/contracttypes/all") ?? new();
            _jobPositions = await Http.GetFromJsonAsync<List<JobPositionDto>>("api/jobpositions/all") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"⚠️ Error cargando catálogos: {ex.Message}", Severity.Warning);
        }
    }

    private async Task ApplyFilters()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var query = $"api/employees/search?" +
                        $"search={Uri.EscapeDataString(_searchTerm ?? "")}" +
                        $"&branchId={_filterBranchId}" +
                        $"&contractTypeId={_filterContractTypeId}" +
                        $"&status={Uri.EscapeDataString(_filterStatus ?? "")}" +
                        $"&jobPositionId={_filterJobPositionId}" +
                        $"&employmentStatus={_filterEmploymentStatus}" +
                        $"&isTrustEmployee={_filterIsTrustEmployee}" +
                        $"&isForeign={_filterIsForeign}" +
                        $"&onProbation={_filterOnProbation}" +
                        $"&isRehire={_filterIsRehire}";

            var result = await Http.GetFromJsonAsync<EmployeeSearchResultDto>(query);
            _employees = result?.Employees ?? new();
            _stats = result?.Stats ?? new EmployeeStatsDto();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error al buscar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ClearFilters()
    {
        _searchTerm = "";
        _filterBranchId = null;
        _filterContractTypeId = null;
        _filterStatus = "";
        _filterJobPositionId = null;
        _filterEmploymentStatus = null;
        _filterIsTrustEmployee = null;
        _filterIsForeign = null;
        _filterOnProbation = null;
        _filterIsRehire = null;
        await ApplyFilters();
    }

    private void OpenNewEmployeeWizard()
    {
        Navigation.NavigateTo("/employees/new");
    }

    private void ViewEmployee(Guid id) => Navigation.NavigateTo($"/employees/{id}");
    private void EditEmployee(Guid id) => Navigation.NavigateTo($"/employees/{id}/edit");

    // Rutas para el menú contextual
    private void ViewPersonalActions(Guid id) => Navigation.NavigateTo($"/employees/{id}/personal-actions");
    private void ViewPayrollHistory(Guid id) => Navigation.NavigateTo($"/employees/{id}/payroll-history");
    private void ViewConcepts(Guid id) => Navigation.NavigateTo($"/employees/{id}/concepts");
    private void ViewShifts(Guid id) => Navigation.NavigateTo($"/employees/{id}/shifts");

    private async Task ToggleActive(EmployeeListDto emp)
    {
        var action = emp.IsActive ? "desactivar" : "activar";

        bool? confirmed = await DialogService.ShowMessageBox(
                    $"¿{action.Substring(0, 1).ToUpper() + action.Substring(1)} empleado?",
                    $"¿Está seguro de {action} a {emp.FullName}?",
                    yesText: "Confirmar", cancelText: "Cancelar");

        if (confirmed == true)
        {
            try
            {
                var response = await Http.PutAsync($"api/employees/{emp.Id}/toggle-active", null);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"✅ Empleado {action}do correctamente", Severity.Success);
                    await ApplyFilters();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"❌ Error: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task ExportToExcel()
    {
        _isExporting = true;
        StateHasChanged();

        try
        {
            var query = $"api/employees/export/excel?" +
                        $"search={Uri.EscapeDataString(_searchTerm ?? "")}" +
                        $"&branchId={_filterBranchId}" +
                        $"&contractTypeId={_filterContractTypeId}" +
                        $"&status={Uri.EscapeDataString(_filterStatus ?? "")}" +
                        $"&jobPositionId={_filterJobPositionId}" +
                        $"&employmentStatus={_filterEmploymentStatus}" +
                        $"&isTrustEmployee={_filterIsTrustEmployee}" +
                        $"&isForeign={_filterIsForeign}" +
                        $"&onProbation={_filterOnProbation}" +
                        $"&isRehire={_filterIsRehire}";

            var response = await Http.GetAsync(query);
            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                var base64 = Convert.ToBase64String(bytes);
                var fileName = $"Empleados_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64,
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", fileName);
                Snackbar.Add("✅ Exportación completada", Severity.Success);
            }
            else
            {
                Snackbar.Add("❌ Error al exportar", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    // Helpers de UI
    private string GetInitials(string firstName, string lastName)
    {
        var f = string.IsNullOrEmpty(firstName) ? "" : firstName.Substring(0, 1).ToUpper();
        var l = string.IsNullOrEmpty(lastName) ? "" : lastName.Substring(0, 1).ToUpper();
        return $"{f}{l}";
    }

    private RenderFragment GetEmploymentStatusChip(EmploymentStatus status) => __builder =>
    {
        switch (status)
        {
            case EmploymentStatus.Active:
                <MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Activo</MudChip>
                break;
            case EmploymentStatus.Suspended:
                <MudChip T="string" Size="Size.Small" Color="Color.Warning">⏸️ Suspendido</MudChip>
                break;
            case EmploymentStatus.Terminated:
                <MudChip T="string" Size="Size.Small" Color="Color.Error">⏹️ Terminado</MudChip>
                break;
            default:
                <MudChip T="string" Size="Size.Small" Color="Color.Default">❓ Desconocido</MudChip>
                break;
        }
    };

    private string GetAntiguedad(DateTime hireDate)
    {
        var now = DateTime.Now;
        var years = now.Year - hireDate.Year;
        var months = now.Month - hireDate.Month;
        if (months < 0) { years--; months += 12; }
        if (years > 0) return $"{years} año{(years > 1 ? "s" : "")}";
        if (months > 0) return $"{months} mes{(months > 1 ? "es" : "")}";
        return "Recién ingresado";
    }
}