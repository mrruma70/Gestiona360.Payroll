@* ✅ Usar el Request de Application.Contracts, NO el Command de Application *@
@using Gestiona360.Payroll.Domain.Shared.Frontend
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">➕ Registrar Nueva Vigencia INSS</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Al guardar, el sistema cerrará automáticamente la configuración anterior un día antes de la fecha de inicio que seleccione.
        </MudAlert>

        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    @* ✅ ESPECIFICAR T="DateOnly" para que coincida con DateOnly? *@
                    <MudDatePicker T="DateOnly" @bind-Date="_effectiveFrom"
                                   Label="📅 Fecha de Inicio *" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_legalRef"
                                  Label="⚖️ Fundamento Legal (Ej: Acuerdo 045-2026)" Required="true" />
                </MudItem>

                <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                <MudItem xs="12" sm="4">
                    @* ✅ AGREGAR 'm' en Min, Max, Step para que sean decimal *@
                    <MudNumericField T="decimal" @bind-Value="_rateWorker"
                                     Label="👷 Trabajador %"
                                     Min="0m" Max="100m" Step="0.01m" Format="F2" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" @bind-Value="_rateEmpSmall"
                                     Label="👔 Empleador <50 emp %"
                                     Min="0m" Max="100m" Step="0.01m" Format="F2" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" @bind-Value="_rateEmpLarge"
                                     Label="👔 Empleador ≥50 emp %"
                                     Min="0m" Max="100m" Step="0.01m" Format="F2" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" @bind-Value="_maxCap"
                                     Label="💰 Nuevo Tope Salarial C$"
                                     Min="0m" Step="100m" Format="N2" Required="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Submit" Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            💾 Guardar Nueva Vigencia
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudBlazor.IMudDialogInstance MudDialog { get; set; }
    private MudForm _form;
    private bool _isSubmitting = false;

    // ✅ CAMBIAR a DateTime? (MudDatePicker solo soporta DateTime)
    private DateTime? _effectiveFrom = DateTime.Today;
    private string _legalRef = "";
    private decimal _rateWorker = 7.00m;
    private decimal _rateEmpSmall = 21.50m;
    private decimal _rateEmpLarge = 22.50m;
    private decimal _maxCap = 50000.00m;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid || !_effectiveFrom.HasValue) return;

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            // ✅ CONVERTIR DateTime a DateOnly al crear el Request
            var dateOnly = DateOnly.FromDateTime(_effectiveFrom.Value);

            var request = new CreateNewINSSValidityRequest
            {
                EffectiveFrom = dateOnly,
                LegalReference = _legalRef,
                RateWorker = _rateWorker,
                RateEmployerSmall = _rateEmpSmall,
                RateEmployerLarge = _rateEmpLarge,
                MaxSalaryCap = _maxCap
            };

            var response = await Http.PostAsJsonAsync("api/inssconfigs/new-validity", request);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Nueva vigencia registrada y anterior cerrada correctamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                Snackbar.Add($"❌ Error: {error?.GetValueOrDefault("error") ?? "Error desconocido"}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error de conexión: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }
}