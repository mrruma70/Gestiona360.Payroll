@page "/login"
@attribute [AllowAnonymous]
@layout LoginLayout
@using Microsoft.AspNetCore.Authorization
@using Gestiona360.Payroll.Frontend.Auth
@using Gestiona360.Payroll.Frontend.Services
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthStateProvider
@inject AuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Iniciar Sesión | Gestiona360 Payroll</PageTitle>

<div class="login-container">
    <!-- PANEL IZQUIERDO: Branding Corporativo -->
    <div class="brand-panel">
        <div class="brand-content">
            <div class="brand-logo">
                <div class="logo-icon">
                    <!-- ✅ IMAGEN DEL LOGO ACTUALIZADA -->
                    <img src="/img/logopayroll.png" alt="Gestiona 360 Payroll Logo" />
                </div>
                <h1 class="brand-title">GESTIONA 360</h1>
                <p class="brand-subtitle">Payroll System</p>
            </div>
@* 
            <div class="brand-features">
                <div class="feature-item">
                    <div class="feature-icon">⚡</div>
                    <div>
                        <h3>Gestión Eficiente</h3>
                        <p>Automatiza procesos de nómina en minutos</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🔒</div>
                    <div>
                        <h3>Seguridad Avanzada</h3>
                        <p>Protección de datos con encriptación JWT</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">📊</div>
                    <div>
                        <h3>Reportes Inteligentes</h3>
                        <p>Análisis en tiempo real de tu nómina</p>
                    </div>
                </div>
            </div> *@

            <div class="brand-footer">
                <p>© 2026 Gestiona360. Todos los derechos reservados.</p>
                <p class="version">Versión 1.0.0</p>
            </div>
        </div>

        <!-- Elementos decorativos -->
        <div class="decorative-circle circle-1"></div>
        <div class="decorative-circle circle-2"></div>
        <div class="decorative-circle circle-3"></div>
    </div>

    <!-- PANEL DERECHO: Formulario -->
    <div class="form-panel">
        <div class="form-container">
            <div class="form-header">
                <h2>
                    Bienvenido de nuevo
                    <span class="wave-hand">👋</span>
                </h2>
                <p>Ingresa tus credenciales para acceder al sistema</p>
            </div>

            <MudForm @ref="_form" Validation="@(new Func<object, IEnumerable<string>>(ValidateLogin))">
                <div class="form-fields">
                    <MudTextField @bind-Value="_email"
                                  Label="Correo Electrónico"
                                  Placeholder="tu@empresa.com"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Class="mb-4"
                                  InputType="InputType.Email"
                                  HelperText="Ingresa tu correo corporativo" />

                    <MudTextField @bind-Value="_password"
                                  Label="Contraseña"
                                  Placeholder="••••••••"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Class="mb-2"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Lock"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  HelperText="Mínimo 6 caracteres"
                                  Immediate="true">
                        <AdornmentContent>
                            <MudIconButton Icon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                           Size="Size.Small"
                                           OnClick="@(() => _showPassword = !_showPassword)"
                                           Title="@(_showPassword ? "Ocultar contraseña" : "Mostrar contraseña")" />
                        </AdornmentContent>
                    </MudTextField>

                    @* <div class="form-options">
                        <MudCheckBox T="bool" @bind-Value="_rememberMe" Label="Recordar sesión" Color="Color.Primary" />
                        <MudLink Href="#" Color="Color.Primary" Typo="Typo.body2">¿Olvidaste tu contraseña?</MudLink>
                    </div> *@
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" 
                              Dense="true" 
                              Class="mb-4"
                              Icon="@Icons.Material.Filled.ErrorOutline"
                              Elevation="0">
                        <MudText Typo="Typo.body2">@_errorMessage</MudText>
                    </MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="HandleLogin"
                           Disabled="@_isLoading"
                           Class="login-button"
                           Style="text-transform: none; font-weight: 600; letter-spacing: 0.5px;">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Validando credenciales...</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" Size="Size.Small" />
                        <span>Iniciar Sesión</span>
                    }
                </MudButton>
            </MudForm>

            <div class="form-footer">
                <MudDivider Class="mb-4" />
                <div class="support-info">
                    <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Size="Size.Small" Color="Color.Default" />
                    <MudText Typo="Typo.caption" Color="Color.Default">
                        ¿Necesitas ayuda? Contacta a 
                        <MudLink Href="mailto:soporte@gestiona360.com" Color="Color.Primary">soporte@gestiona360.com</MudLink>
                    </MudText>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ============================================
       CONTENEDOR PRINCIPAL - SPLIT SCREEN
       ============================================ */
    .login-container {
        display: flex;
        min-height: 100vh;
        background: #f5f5f7;
        position: relative;
        overflow: hidden;
    }

    /* ============================================
       PANEL IZQUIERDO - BRANDING
       ============================================ */
    .brand-panel {
        flex: 1;
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1a1a1a 100%);
        color: white;
        padding: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .brand-content {
        position: relative;
        z-index: 2;
        max-width: 500px;
        width: 100%;
    }

    .brand-logo {
        margin-bottom: 60px;
        text-align: center;
    }

    /* ✅ CORRECCIÓN PARA IMAGEN PNG */
    .logo-icon {
        width: 120px; /* Tamaño ajustado para logo PNG */
        height: 120px;
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: float 3s ease-in-out infinite;
    }

    .logo-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* Mantiene proporciones del logo */
        filter: drop-shadow(0 8px 16px rgba(0,0,0,0.4)); /* Sombra para resaltar sobre fondo oscuro */
    }

    .brand-title {
        font-size: 32px;
        font-weight: 700;
        color: #FFD700;
        margin: 0;
        letter-spacing: 2px;
    }

    .brand-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
        margin-top: 8px;
        letter-spacing: 4px;
        text-transform: uppercase;
    }

    .brand-features {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .feature-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 16px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 215, 0, 0.1);
        transition: all 0.3s ease;
    }

    .feature-item:hover {
        background: rgba(255, 215, 0, 0.08);
        transform: translateX(8px);
        border-color: rgba(255, 215, 0, 0.3);
    }

    .feature-icon {
        font-size: 28px;
        flex-shrink: 0;
    }

    .feature-item h3 {
        font-size: 16px;
        font-weight: 600;
        margin: 0 0 4px 0;
        color: #FFD700;
    }

    .feature-item p {
        font-size: 13px;
        margin: 0;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.5;
    }

    .brand-footer {
        margin-top: 60px;
        text-align: center;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.5);
    }

    .brand-footer .version {
        margin-top: 4px;
        font-family: monospace;
        color: rgba(255, 215, 0, 0.6);
    }

    /* Círculos decorativos */
    .decorative-circle {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255, 215, 0, 0.15) 0%, transparent 70%);
