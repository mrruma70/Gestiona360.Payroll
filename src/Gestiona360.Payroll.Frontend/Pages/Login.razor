    /* ============================================
       PANEL DERECHO - FORMULARIO
       ============================================ */
    .form-panel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        background: white;
    }

    .form-container {
        width: 100%;
