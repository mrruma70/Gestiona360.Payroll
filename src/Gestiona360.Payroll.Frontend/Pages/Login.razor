    /* ============================================
       ANIMACIONES
       ============================================ */
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }

    @@keyframes pulse {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.1); }
    }

    /* ============================================
       RESPONSIVE - MÓVILES
       ============================================ */
    @@media (max-width: 960px) {
        .login-container {
            flex-direction: column;
        }

        .brand-panel {
            padding: 40px 20px;
            min-height: auto;
        }

        .brand-features {
            display: none;
        }

        .brand-logo {
            margin-bottom: 20px;
        }

        .logo-icon {
            width: 80px; /* Más pequeño en móvil */
            height: 80px;
        }

        .brand-title {
            font-size: 24px;
        }

        .brand-footer {
            margin-top: 20px;
        }

        .form-panel {
            padding: 30px 20px;
        }

        .form-header h2 {
            font-size: 22px;
        }
    }

    @@media (max-width: 480px) {
        .form-options {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }
    }

    .wave-hand {
        display: inline-block;
        animation: wave-animation 1.8s ease-in-out infinite;
        transform-origin: 70% 70%;
    }

    @@keyframes wave-animation {
        0% {
            transform: rotate(0deg);
        }

        10% {
            transform: rotate(14deg);
        }

        20% {
            transform: rotate(-8deg);
        }

        30% {
            transform: rotate(14deg);
        }

        40% {
            transform: rotate(-4deg);
        }

        50% {
            transform: rotate(10deg);
        }

        60% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(0deg);
        }
    }
</style>

@code {
    private MudForm? _form;
    private string _email = "admin@localhost";
    private string _password = "Admin123!";
    private bool _isLoading = false;
    private bool _showPassword = false;
    private bool _rememberMe = false;
    private string? _errorMessage;

    // Validación en tiempo real
    private IEnumerable<string> ValidateLogin(object arg)
    {
        var errors = new List<string>();
        
        if (string.IsNullOrWhiteSpace(_email))
            errors.Add("El correo electrónico es obligatorio");
        else if (!_email.Contains("@"))
            errors.Add("Ingresa un correo electrónico válido");
            
        if (string.IsNullOrWhiteSpace(_password))
            errors.Add("La contraseña es obligatoria");
        else if (_password.Length < 6)
            errors.Add("La contraseña debe tener al menos 6 caracteres");
            
        return errors;
    }

    private async Task HandleLogin()
    {
        _errorMessage = null;

        if (_form == null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            Console.WriteLine($"🔍 [Login] Intentando login con: {_email}");

            var result = await AuthService.Login(_email, _password);

            Console.WriteLine($"🔍 [Login] Success: {result.Success}");
            Console.WriteLine($"🔍 [Login] Token length: {result.Token?.Length ?? 0}");

            if (result.Success && !string.IsNullOrEmpty(result.Token))
            {
                Console.WriteLine($"✅ [Login] Guardando token...");

                await AuthStateProvider.SetTokenAsync(result.Token);

                Console.WriteLine($"✅ [Login] Token guardado. Redirigiendo a /");

                Snackbar.Add($"✅ Bienvenido {result.User.FullName}", Severity.Success);

                Navigation.NavigateTo("/", forceLoad: false);
            }
            else
            {
                _errorMessage = result.Message;
                Snackbar.Add($"❌ {result.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "No se pudo conectar con el servidor. Intenta nuevamente.";
            Console.WriteLine($"❌ [Login] Excepción: {ex.Message}");
            Snackbar.Add($"❌ {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}